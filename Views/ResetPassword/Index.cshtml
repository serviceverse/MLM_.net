@{
    ViewData["Title"] = "Reset Password";
    Layout = null; // Assuming this is an standalone page without the admin sidebar, like login
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MLM</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Custom styles to match the React app */
        body {
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }
    </style>
</head>
<body>
    <div class="min-h-screen w-full grid place-items-center bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white px-6">
        <div class="w-full bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8">
            <h1 class="text-2xl font-bold mb-2">Set a new password</h1>
            <p class="text-gray-400 mb-6 text-sm">Choose a strong password.</p>

            <form class="grid grid-cols-1 lg:grid-cols-2 gap-4 relative">
                <!-- New Password -->
                <div>
                    <label class="text-sm text-gray-200 block mb-1">New password</label>
                    <div class="relative">
                        <input type="password" required autocomplete="new-password" placeholder="********" class="w-full bg-white/5 border border-white/20 rounded-sm py-2 px-3 text-sm pr-12 text-white placeholder:text-gray-400 focus:border-emerald-400 focus:ring-2 focus:ring-emerald-400/20 outline-none" />
                        <button type="button" aria-label="Show password" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white transition-colors p-1 rounded-lg hover:bg-white/10">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                        </button>
                    </div>
                </div>

                <!-- Confirm Password -->
                <div>
                    <label class="text-sm text-gray-200 block mb-1">Confirm password</label>
                    <div class="relative">
                        <input type="password" required autocomplete="new-password" placeholder="********" class="w-full bg-white/5 border border-white/20 rounded-sm py-2 px-3 text-sm pr-12 text-white placeholder:text-gray-400 focus:border-emerald-400 focus:ring-2 focus:ring-emerald-400/20 outline-none" />
                        <button type="button" aria-label="Show confirm password" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white transition-colors p-1 rounded-lg hover:bg-white/10">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                        </button>
                    </div>
                </div>

                <button type="submit" class="w-full bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-600 hover:to-teal-700 rounded-sm py-2 px-3 text-sm font-semibold transition-colors mt-2">
                    Reset password
                </button>
            </form>
        </div>
    </div>
</body>
</html>
