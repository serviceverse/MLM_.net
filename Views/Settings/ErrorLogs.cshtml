@{
    ViewData["Title"] = "Error Logs";
    // Mock data for UI demonstration
    var logs = new[] {
        new { Type = "Error", Title = "Server Crash", Date = "2025-03-01" },
        new { Type = "Warning", Title = "High Memory Usage", Date = "2025-03-02" },
        new { Type = "Error", Title = "Database Connection Failed", Date = "2025-03-03" },
        new { Type = "Info", Title = "System Restarted", Date = "2025-03-04" },
        new { Type = "Warning", Title = "Slow Response Time", Date = "2025-03-05" }
    };
}

<div class="p-4 md:p-6 space-y-4">
    <div>
        <h1 class="text-2xl font-bold text-[var(--text-primary)]">Error Logs</h1>
        <p class="text-[var(--text-secondary)]">View and filter system error logs</p>
    </div>

    <div class="bg-white border border-[var(--border-secondary)] rounded-sm shadow-none">
        
        <!-- Filters -->
        <div class="p-4 border-b border-[var(--border-secondary)] flex flex-wrap items-end gap-4">
            <div class="space-y-1">
                <label class="text-[var(--text-primary)] text-sm font-medium mb-1 block">From Date</label>
                <input type="datetime-local" class="bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-2 px-3 text-sm outline-none focus:ring-1 focus:ring-[var(--button-primary-bg)]" />
            </div>

            <div class="space-y-1">
                <label class="text-[var(--text-primary)] text-sm font-medium mb-1 block">To Date</label>
                <input type="datetime-local" class="bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-2 px-3 text-sm outline-none focus:ring-1 focus:ring-[var(--button-primary-bg)]" />
            </div>

            <button type="button" class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] hover:text-[var(--button-primary-hover-text)] px-4 py-2 rounded-sm text-sm font-semibold h-9">
                Search
            </button>
        </div>

        <!-- Table Content -->
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-[var(--border-secondary)] hover:bg-[var(--bg-tertiary)] even:bg-[var(--bg-secondary)]/40 transition-none">
                        <th class="py-2 px-3 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold uppercase">Type</th>
                        <th class="py-2 px-3 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold uppercase">Title</th>
                        <th class="py-2 px-3 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold uppercase">Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in logs)
                    {
                        <tr class="border-b border-[var(--border-secondary)] hover:bg-[var(--bg-tertiary)] even:bg-[var(--bg-secondary)]/40 transition-none">
                            <td class="py-2 px-3 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)]">
                                @if (log.Type == "Error")
                                {
                                    <span class="inline-flex items-center rounded-sm border px-2.5 py-0.5 text-[10px] font-semibold bg-red-500/20 text-red-600 border-red-500/30">@log.Type</span>
                                }
                                else if (log.Type == "Warning")
                                {
                                    <span class="inline-flex items-center rounded-sm border px-2.5 py-0.5 text-[10px] font-semibold bg-yellow-500/20 text-yellow-600 border-yellow-500/30">@log.Type</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center rounded-sm border px-2.5 py-0.5 text-[10px] font-semibold bg-blue-500/20 text-blue-600 border-blue-500/30">@log.Type</span>
                                }
                            </td>
                            <td class="py-2 px-3 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)] font-medium">@log.Title</td>
                            <td class="py-2 px-3 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)]">@log.Date</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>
