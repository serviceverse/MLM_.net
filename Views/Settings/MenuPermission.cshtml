@{
    ViewData["Title"] = "Menu Permissions";
    var roles = ViewBag.Roles as List<MLM.Models.Role>;
    var currentRoleId = ViewBag.CurrentRoleId as int?;
    var groups = ViewBag.NavigationGroups as List<MLM.Models.NavigationGroup>;
    var items = ViewBag.NavigationItems as List<MLM.Models.NavigationItem>;
    var actions = ViewBag.NavigationActions as List<MLM.Models.NavigationAction>;
    var permittedMenus = ViewBag.PermittedMenus as List<int> ?? new List<int>();
    var permittedActions = ViewBag.PermittedActions as List<int> ?? new List<int>();
}

<div class="min-h-screen bg-primary text-[var(--text-primary)] flex flex-col p-8">
    <div class="w-full w-full space-y-8">
        <!-- Header -->
        <div>
            <h1 class="text-2xl font-bold text-[var(--text-primary)]">Menu Permissions</h1>
            <p class="text-[var(--text-secondary)]">Configure sidebar menus and actions for each role</p>
        </div>

        <!-- Role Selector -->
        <div class="bg-white border border-[var(--border-secondary)] rounded-sm p-6">
            <form id="roleForm" method="get" class="flex items-end gap-4">
                <div class="space-y-2">
                    <label class="text-[var(--text-tertiary)] font-medium block">Select Role <span class="text-red-400">*</span></label>
                    <select name="roleId" onchange="document.getElementById('roleForm').submit()" class="w-64 bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-sm py-2 px-3 text-sm outline-none">
                        @if(roles != null)
                        {
                            @foreach (var role in roles)
                            {
                                if(currentRoleId == role.Id)
                                {
                                    <option value="@role.Id" selected>@role.Name</option>
                                }
                                else
                                {
                                    <option value="@role.Id">@role.Name</option>
                                }
                            }
                        }
                    </select>
                </div>
            </form>
        </div>

        @if(currentRoleId != null && groups != null)
        {
            <form method="post" asp-action="SaveMenuPermissions">
                <input type="hidden" name="roleId" value="@currentRoleId" />

                <div class="space-y-4 pb-20">
                    @foreach (var group in groups)
                    {
                        var groupItems = items?.Where(i => i.GroupId == group.Id).OrderBy(i => i.Sequence).ToList();
                        if (groupItems != null && groupItems.Any())
                        {
                            <div class="space-y-4">
                                <h3 class="text-xl font-semibold text-[var(--text-primary)] border-b border-[var(--border-secondary)] pb-2">@group.Name</h3>
                                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                                    @foreach (var item in groupItems)
                                    {
                                        var isMenuChecked = permittedMenus.Contains(item.Id);
                                        var itemActions = actions?.Where(a => a.ItemId == item.Id).ToList() ?? new List<MLM.Models.NavigationAction>();

                                        <div class="bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] rounded-2xl p-5 space-y-3">
                                            <div class="flex items-center space-x-3">
                                                <input type="checkbox" name="menuIds" value="@item.Id" id="menu_@item.Id" 
                                                       @(isMenuChecked ? "checked" : "")
                                                       onchange="toggleActions(@item.Id, this.checked)"
                                                       class="w-5 h-5 rounded border-[var(--border-secondary)] bg-[var(--bg-tertiary)] text-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] cursor-pointer" />
                                                <label for="menu_@item.Id" class="font-medium text-[var(--text-primary)] cursor-pointer select-none text-lg">@item.Name</label>
                                            </div>

                                            @if(itemActions.Any())
                                            {
                                                <div class="pl-8 space-y-2 pt-2 border-t border-[var(--border-secondary)]/50 mt-2">
                                                    @foreach (var action in itemActions)
                                                    {
                                                        var isActionChecked = permittedActions.Contains(action.Id);
                                                        <div class="flex items-center space-x-3">
                                                            <input type="checkbox" name="actionIds" value="@action.Id" id="action_@action.Id"
                                                                   data-menu-id="@item.Id"
                                                                   @(isActionChecked ? "checked" : "")
                                                                   @(isMenuChecked ? "" : "disabled")
                                                                   class="w-4 h-4 rounded border-[var(--border-secondary)] bg-[var(--bg-tertiary)] text-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] cursor-pointer" />
                                                            <label for="action_@action.Id" class="text-[var(--text-secondary)] text-sm cursor-pointer select-none">@action.Name</label>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>

                <!-- Fixed Save Button -->
                <div class="fixed bottom-0 left-0 w-full bg-[var(--bg-secondary)] border-t border-[var(--border-primary)] p-4 shadow-lg z-50">
                    <div class="col-span-full mt-4 w-full flex justify-end">
                        <button type="submit" class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] hover:text-[var(--button-primary-hover-text)] font-semibold px-10 py-2 rounded-sm text-sm transition-colors flex items-center shadow-lg shadow-[var(--button-primary-bg)]/20">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                            Save Permissions
                        </button>
                    </div>
                </div>
            </form>
        }
        else if (roles == null || !roles.Any())
        {
            <div class="text-center py-10 bg-[var(--bg-secondary)] rounded-3xl border border-[var(--border-primary)]">
                <p class="text-[var(--text-secondary)] text-lg">No roles found. Please <a href="/Role/Index" class="text-[var(--button-primary-bg)] hover:underline">create a role</a> first.</p>
            </div>
        }
    </div>
</div>

<script>
    function toggleActions(menuId, isChecked) {
        var checkboxes = document.querySelectorAll('input[type="checkbox"][data-menu-id="' + menuId + '"]');
        checkboxes.forEach(function(cb) {
            cb.disabled = !isChecked;
            if (!isChecked) {
                cb.checked = false;
            }
        });
    }
</script>
