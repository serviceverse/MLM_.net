@{
    ViewData["Title"] = "Menu Management";
    // Mock data for UI demonstration
    var menus = new[] {
        new { Name = "Dashboard", GroupName = "Main", Title = "Dashboard", Sequence = 1 },
        new { Name = "Users", GroupName = "Main", Title = "User Management", Sequence = 2 },
        new { Name = "Settings", GroupName = "System", Title = "App Settings", Sequence = 3 }
    };
}

<div class="p-4 md:p-6 space-y-4">
    <div class="flex flex-wrap justify-between items-center gap-4">
        <div>
            <h1 class="text-2xl font-bold text-[var(--text-primary)]">Menu Management</h1>
            <p class="text-[var(--text-secondary)]">Manage navigation items and groups</p>
        </div>
        <button type="button" class="bg-[#ff8091] text-white rounded-full flex items-center justify-center hover:bg-[#f74f65] transition-colors w-10 h-10 shadow-sm" title="Add Menu Item">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
        </button>
    </div>

    <div class="bg-white border border-[var(--border-secondary)] rounded-sm shadow-none">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-[var(--border-secondary)] hover:bg-[var(--bg-tertiary)] even:bg-[var(--bg-secondary)]/40 transition-none">
                        <th class="py-2 px-3 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold uppercase w-10">Icon</th>
                        <th class="py-2 px-3 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold uppercase">Menu Item Name</th>
                        <th class="py-2 px-3 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold uppercase">Menu Group</th>
                        <th class="py-2 px-3 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold uppercase">Title</th>
                        <th class="py-2 px-3 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold uppercase">Sequence</th>
                        <th class="py-2 px-3 text-[11px] whitespace-nowrap text-center text-[var(--text-secondary)] font-semibold uppercase w-28">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in menus)
                    {
                        <tr class="border-b border-[var(--border-secondary)] hover:bg-[var(--bg-tertiary)] even:bg-[var(--bg-secondary)]/40 transition-none">
                            <td class="py-2 px-3 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)] text-center">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mx-auto text-[var(--text-secondary)]"><path d="m9 18 6-6-6-6"/></svg>
                            </td>
                            <td class="py-2 px-3 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)] font-medium">@item.Name</td>
                            <td class="py-2 px-3 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)]">@item.GroupName</td>
                            <td class="py-2 px-3 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)]">@item.Title</td>
                            <td class="py-2 px-3 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)]">@item.Sequence</td>
                            <td class="py-1 px-2 text-[12px] whitespace-nowrap text-center flex justify-center items-center space-x-1">
                                <button class="p-1.5 text-[var(--text-secondary)] hover:text-[var(--button-primary-bg)] hover:bg-[var(--bg-tertiary)] rounded-sm transition-colors" title="Edit">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                                </button>
                                <button class="p-1.5 text-red-400 hover:text-red-500 hover:bg-red-50 rounded-sm transition-colors" title="Delete">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                                </button>
                                <button class="p-1.5 text-[#ff8091] hover:text-[#f74f65] hover:bg-[#ff8091]/10 rounded-sm transition-colors" title="Action">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/><path d="M12 8v8"/></svg>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
