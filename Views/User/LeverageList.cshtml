@{
    ViewData["Title"] = "Account List (Leverage)";
}
<div class="p-2 md:p-4">
    
        <!-- Page Header -->
    <div class="mb-2">
        <h1 class="text-2xl font-bold text-[var(--text-primary)]">Account List</h1>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Manage your Iman trading accounts leverage</p>
    </div>

    <!-- Main Card -->
    <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-sm shadow-none">
            <div class="px-3 py-2 border-b border-[var(--border-secondary)] flex flex-wrap items-center justify-between gap-4">
                <div class="flex items-center space-x-2">
                    <span class="text-[var(--text-secondary)]">Show</span>
                    <select class="w-20 bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-md py-2 px-3 outline-none">
                        <option>10</option>
                    </select>
                    <span class="text-[var(--text-secondary)]">entries</span>
                </div>
                <div class="flex items-center space-x-2">
                    <span class="text-[var(--text-secondary)]">Search:</span>
                    <div class="relative">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--text-tertiary)] absolute left-3 top-1/2 -translate-y-1/2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                        <input type="text" placeholder="Search accounts..." class="pl-10 bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] w-64 py-2 px-3 rounded-md outline-none focus:ring-2" />
                    </div>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-[var(--bg-tertiary)]">
                        <tr>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Serial No.</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Iman ID</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Account Type</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Name</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Date</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Leverage</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="7" class="py-8 text-center text-[var(--text-secondary)]">No data available in table</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="flex items-center justify-between mt-6">
                <div class="text-[var(--text-secondary)]">Showing 0 to 0 of 0 entries</div>
                <div class="flex items-center space-x-2">
                    <button disabled class="border border-[var(--border-secondary)] text-[var(--text-secondary)] bg-transparent px-3 py-1 text-sm rounded-md opacity-50 cursor-not-allowed">Previous</button>
                    <button class="bg-[var(--button-primary-bg)] text-[var(--button-primary-text)] px-3 py-1 text-sm rounded-md">1</button>
                    <button disabled class="border border-[var(--border-secondary)] text-[var(--text-secondary)] bg-transparent px-3 py-1 text-sm rounded-md opacity-50 cursor-not-allowed">Next</button>
                </div>
            </div>
        </div>
    </div>
</div>
