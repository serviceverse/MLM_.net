@{
    ViewData["Title"] = "Account List";
}
<div class="p-2 md:p-4">
    
        <!-- Page Header -->
    <div class="mb-2">
        <h1 class="text-2xl font-bold text-[var(--text-primary)]">Account List</h1>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Manage your Crib trading accounts</p>
    </div>

    <!-- Main Card -->
    <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-sm shadow-none">
            <div class="px-3 py-2 border-b border-[var(--border-secondary)] flex flex-wrap items-center justify-between gap-4">
                <div class="flex items-center space-x-2">
                    <span class="text-[var(--text-secondary)]">Show</span>
                    <select class="w-20 bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-md py-2 px-3 outline-none">
                        <option>10</option>
                    </select>
                    <span class="text-[var(--text-secondary)]">entries</span>
                </div>
                <div class="flex items-center space-x-2">
                    <span class="text-[var(--text-secondary)]">Search:</span>
                    <div class="relative">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                        <input type="text" placeholder="Search accounts..." class="pl-10 bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] w-64 py-2 px-3 rounded-md outline-none focus:ring-2" />
                    </div>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-[var(--border-secondary)] hover:bg-[var(--bg-tertiary)] even:bg-[var(--bg-secondary)]/40 transition-none">
                            <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold">#</th>
                            <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold">Crib ID</th>
                            <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold">TYPE</th>
                            <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold">USER</th>
                            <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold">EMAIL</th>
                            <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold">PASSWORD</th>
                            <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold">LEVERAGE</th>
                            <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold">DATE</th>
                            <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold">ACTION</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="9" class="py-8 text-center text-[var(--text-tertiary)]">No data available</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            
            <div class="px-3 py-2 border-t border-[var(--border-secondary)] flex flex-wrap items-center justify-between gap-4">
                <div class="text-[var(--text-secondary)]">Page 1 of 1</div>
                <div class="flex items-center space-x-2">
                    <button disabled class="border border-[var(--border-secondary)] text-[var(--text-secondary)] bg-transparent px-3 py-1 text-sm rounded-md opacity-50 cursor-not-allowed">Previous</button>
                    <button class="bg-[var(--button-primary-bg)] text-[var(--button-primary-text)] px-3 py-1 text-sm rounded-md">1</button>
                    <button disabled class="border border-[var(--border-secondary)] text-[var(--text-secondary)] bg-transparent px-3 py-1 text-sm rounded-md opacity-50 cursor-not-allowed">Next</button>
                </div>
            </div>
        </div>
    </div>
</div>
