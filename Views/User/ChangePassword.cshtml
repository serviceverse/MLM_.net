@{
    ViewData["Title"] = "Update User Password";
}
<div class="custome-scroll min-h-screen bg-primary text-[var(--text-primary)] p-8">
    <div class="w-full space-y-8">
        <div>
            <h1 class="text-4xl font-bold mb-4">Update User Password</h1>
            <p class="text-[var(--text-secondary)] mb-6">Search a user and update their CRM password.</p>
        </div>

        <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-3xl p-8 space-y-6">
            <div class="space-y-2 relative">
                <label class="text-[var(--text-primary)]">Search User</label>
                <input type="text" placeholder="Search Client..." class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-xl py-3 px-3 outline-none focus:ring-2 focus:ring-[var(--button-primary-bg)]" />
            </div>

            <div class="relative">
                <input type="password" placeholder="Enter new CRM password" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] rounded-xl py-3 px-3 outline-none focus:ring-2 focus:ring-[var(--button-primary-bg)]" />
                <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 p-2 bg-[var(--button-secondary-bg)] text-[var(--button-secondary-text)] rounded-lg hover:bg-[var(--button-secondary-hover-bg)]">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
            </div>

            <button class="bg-[var(--button-primary-bg)] hover:opacity-90 text-[var(--button-primary-text)] px-8 py-3 rounded-xl font-semibold w-full">
                Update Password
            </button>
        </div>
    </div>
