@{
    ViewData["Title"] = "User Password List";
}
<div class="p-6 md:p-8">
    
        <!-- Page Header -->
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-[var(--text-primary)]">User Password List</h1>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Manage user accounts and passwords</p>
    </div>

    <!-- Main Card -->
    <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-xl shadow-sm">
            <div class="px-6 py-4 border-b border-[var(--border-secondary)] flex flex-wrap items-center justify-between gap-4">
                <div class="flex items-center space-x-2">
                    <span class="text-[var(--text-secondary)]">Show</span>
                    <select class="w-20 bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-md py-2 px-3 outline-none">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                    </select>
                    <span class="text-[var(--text-secondary)]">entries</span>
                </div>

                <div class="flex items-center space-x-2">
                    <span class="text-[var(--text-secondary)]">Search:</span>
                    <div class="relative">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 transform -translate-y-1/2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                        <input type="text" placeholder="Search by name, email, username..." class="pl-10 bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] w-64 py-2 px-3 rounded-md outline-none focus:ring-2" />
                    </div>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-[var(--border-secondary)]">
                            <th class="py-3 px-4 text-left text-[var(--text-secondary)] font-semibold">#</th>
                            <th class="py-3 px-4 text-left text-[var(--text-secondary)] font-semibold">USERNAME</th>
                            <th class="py-3 px-4 text-left text-[var(--text-secondary)] font-semibold">FULL NAME</th>
                            <th class="py-3 px-4 text-left text-[var(--text-secondary)] font-semibold">EMAIL</th>
                            <th class="py-3 px-4 text-left text-[var(--text-secondary)] font-semibold">CONTACT</th>
                            <th class="py-3 px-4 text-left text-[var(--text-secondary)] font-semibold">PASSWORD HASH</th>
                            <th class="py-3 px-4 text-left text-[var(--text-secondary)] font-semibold">STATUS</th>
                            <th class="py-3 px-4 text-left text-[var(--text-secondary)] font-semibold">ACTION</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="8" class="py-8 text-center text-[var(--text-tertiary)]">No users available</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="flex items-center justify-between mt-6">
                <div class="text-[var(--text-secondary)]">Showing 0 to 0 of 0 entries</div>
                <div class="flex items-center space-x-2">
                    <button disabled class="border border-[var(--border-secondary)] text-[var(--text-secondary)] bg-transparent px-3 py-1 text-sm rounded-md opacity-50 cursor-not-allowed">Previous</button>
                    <span class="px-3 py-1 text-sm bg-[var(--button-primary-bg)] text-[var(--button-primary-text)] rounded">1 / 1</span>
                    <button disabled class="border border-[var(--border-secondary)] text-[var(--text-secondary)] bg-transparent px-3 py-1 text-sm rounded-md opacity-50 cursor-not-allowed">Next</button>
                </div>
            </div>
        </div>
    </div>
</div>
