@{
    ViewData["Title"] = "Add Bank Details";
}
<div class="p-6 md:p-8">
    <div class="page-scroll-content px-8 py-6">
        <div class="w-full space-y-8">
            <!-- Header -->
            <div>
                <h1 class="text-2xl font-bold text-[var(--text-primary)]">
                    Add Bank Details
                </h1>
                <p class="text-[var(--text-secondary)]">
                    Provide banking information for account verification
                </p>
            </div>

            <!-- Form -->
            <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-xl shadow-sm p-6 md:p-8">
            <form class="flex-1 flex flex-col">
                    <!-- Customer Name Search -->
                    <div class="space-y-2">
                        <label class="text-[var(--text-primary)] text-sm font-medium mb-1">
                            Customer Name <span class="text-red-400">*</span>
                        </label>
                        <div class="relative">
                            <input type="search" placeholder="Search customer" class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-sm py-2 px-3 text-sm outline-none focus:ring-2" />
                        </div>
                    </div>

                    <!-- Row 1: Account Name / Account No / IFSC-Swift -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <!-- Account Name -->
                        <div class="space-y-2">
                            <label class="text-[var(--text-primary)] text-sm font-medium mb-1">
                                Account Holder's Name <span class="text-red-400">*</span>
                            </label>
                            <input type="text" placeholder="Enter Account Holder's Name" class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-sm py-2 px-3 text-sm outline-none focus:ring-2" required />
                        </div>

                        <!-- Account No -->
                        <div class="space-y-2">
                            <label class="text-[var(--text-primary)] text-sm font-medium mb-1">
                                Account No. <span class="text-red-400">*</span>
                            </label>
                            <input type="text" placeholder="Enter account number" class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-sm py-2 px-3 text-sm outline-none focus:ring-2" required />
                        </div>

                        <!-- IFSC/Swift Code -->
                        <div class="space-y-2">
                            <label class="text-[var(--text-primary)] text-sm font-medium mb-1">
                                IFSC/Swift Code <span class="text-red-400">*</span>
                            </label>
                            <input type="text" placeholder="Enter ifsc/swift code" class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-sm py-2 px-3 text-sm outline-none focus:ring-2" required />
                        </div>
                    </div>

                    <!-- Row 2: IBAN / Bank Name / Bank Address -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <!-- IBAN -->
                        <div class="space-y-2">
                            <label class="text-[var(--text-primary)] text-sm font-medium mb-1">
                                IBAN No.
                            </label>
                            <input type="text" placeholder="Enter iban number" class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-sm py-2 px-3 text-sm outline-none focus:ring-2" />
                        </div>

                        <!-- Bank Name -->
                        <div class="space-y-2">
                            <label class="text-[var(--text-primary)] text-sm font-medium mb-1">
                                Bank Name <span class="text-red-400">*</span>
                            </label>
                            <input type="text" placeholder="Enter bank name" class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-sm py-2 px-3 text-sm outline-none focus:ring-2" required />
                        </div>

                        <!-- Bank Address -->
                        <div class="space-y-2">
                            <label class="text-[var(--text-primary)] text-sm font-medium mb-1">
                                Bank Address
                            </label>
                            <input type="text" placeholder="Enter bank address" class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-sm py-2 px-3 text-sm outline-none focus:ring-2" />
                        </div>
                    </div>

                    <!-- Row 3: Country / Book Bank -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <!-- Country -->
                        <div class="space-y-2">
                            <label class="text-[var(--text-primary)] text-sm font-medium mb-1">
                                Country <span class="text-red-400">*</span>
                            </label>
                            <select class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-2 px-3 text-sm outline-none focus:ring-2 focus:ring-[var(--button-primary-bg)]">
                                <option value="">Please Choose...</option>
                                <option value="United States">United States</option>
                                <option value="United Kingdom">United Kingdom</option>
                                <option value="Canada">Canada</option>
                                <option value="Australia">Australia</option>
                                <option value="Germany">Germany</option>
                                <option value="France">France</option>
                                <option value="Japan">Japan</option>
                                <option value="India">India</option>
                                <option value="Singapore">Singapore</option>
                                <option value="Hong Kong">Hong Kong</option>
                                <option value="Switzerland">Switzerland</option>
                                <option value="Netherlands">Netherlands</option>
                            </select>
                        </div>

                        <!-- Book Bank -->
                        <div class="space-y-2">
                            <label class="text-[var(--text-primary)] text-sm font-medium mb-1">
                                Bank Book <span class="text-red-400">*</span>
                            </label>
                            <div class="relative">
                                <input type="file" accept=".pdf,.jpg,.jpeg,.png" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" required />
                                <div class="bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] hover:border-[var(--button-primary-bg)] rounded-sm py-2 px-3 text-sm flex items-center justify-between transition-colors">
                                    <div class="col-span-full mt-4 flex items-center space-x-3">
                                        <button type="button" class="bg-[var(--button-secondary-bg)] hover:bg-[var(--button-secondary-hover-bg)] text-[var(--button-secondary-text)] hover:text-[var(--button-secondary-hover-text)] px-3 py-1 text-sm rounded">
                                            Choose File
                                        </button>
                                        <span class="text-[var(--text-tertiary)] text-sm">No file chosen</span>
                                    </div>
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--text-tertiary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
                                </div>
                            </div>
                            <p class="text-xs text-[var(--text-tertiary)]">
                                Supported: PDF, JPG, PNG. Max 5MB.
                            </p>
                        </div>

                        <div></div>
                    </div>

                    <!-- Submit Button -->
                    <div class="col-span-full mt-4 flex justify-start">
                        <button type="submit" class="bg-[var(--button-primary-bg)] hover:opacity-90 text-[var(--button-primary-text)] px-6 py-2 rounded-sm text-sm font-semibold disabled:opacity-50">
                            Submit
                        </button>
                    </div>
                </form>
            </div>

            <!-- Info Section -->
            <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-2xl p-6 opacity-80">
                <h3 class="text-lg font-semibold text-[var(--text-primary)] mb-3">
                    Important Information
                </h3>
                <ul class="space-y-2 text-[var(--text-secondary)] text-sm">
                    <li>â€¢ Ensure all bank details are accurate to avoid processing delays</li>
                    <li>â€¢ The account name should match your registered trading account name</li>
                    <li>â€¢ Upload a clear copy of your bank statement or passbook</li>
                    <li>â€¢ Processing time for bank verification is typically 1â€“2 business days</li>
                </ul>
            </div>
        </div>
    </div>
</div>
