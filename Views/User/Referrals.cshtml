@{
    ViewData["Title"] = "User Referral Network";
}
<div class="p-6 md:p-8">
    
        <div>
            <button class="border border-[var(--border-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] bg-transparent p-2 rounded-md">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            </button>
        </div>

        <div class="flex flex-col items-center justify-center pt-4 pb-8 space-y-4">
            <div class="w-20 h-20 bg-gradient-to-br from-purple-400 to-purple-600 rounded-full flex items-center justify-center shadow-lg shadow-purple-500/20">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="16" y="16" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="9" y="2" width="6" height="6" rx="1"/><path d="M5 16v-3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3"/><path d="M12 12V8"/></svg>
            </div>
            <h1 class="text-4xl md:text-5xl font-bold text-center tracking-tight text-[var(--text-primary)]">
                User Referral Network
            </h1>
            <p class="text-lg text-[var(--text-secondary)] text-center">
                Viewing referral tree for User ID: <span class="font-medium text-[var(--text-primary)]"></span>
            </p>
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
            <div class="flex items-center space-x-3 bg-[var(--bg-secondary)] border border-[var(--border-secondary)] rounded-full px-5 py-2.5 shadow-sm">
                <span class="text-[var(--text-secondary)] text-sm whitespace-nowrap">Export Levels:</span>
                <select class="bg-transparent border-none outline-none text-[var(--text-primary)] font-medium">
                    <option value="7">7 Levels</option>
                    <option value="10">10 Levels</option>
                    <option value="15">15 Levels</option>
                    <option value="all">All Levels</option>
                </select>
            </div>
            <button class="bg-blue-600 hover:bg-blue-700 text-white shadow-md shadow-blue-500/20 rounded-full px-8 py-3 text-base font-medium flex items-center space-x-2 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                <span>Download Excel</span>
            </button>
        </div>

        <!-- Network Statistics -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 pt-6">
            <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-2xl p-6 text-center">
                <div class="w-12 h-12 bg-blue-400/20 rounded-full flex items-center justify-center mx-auto mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="16" y="16" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="9" y="2" width="6" height="6" rx="1"/><path d="M5 16v-3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3"/><path d="M12 12V8"/></svg>
                </div>
                <h3 class="text-2xl font-bold">â€”</h3>
                <p class="text-[var(--text-secondary)] text-sm">Total Nodes</p>
            </div>
            <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-2xl p-6 text-center">
                <div class="w-12 h-12 bg-purple-400/20 rounded-full flex items-center justify-center mx-auto mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <h3 class="text-2xl font-bold">â€”</h3>
                <p class="text-[var(--text-secondary)] text-sm">Sub IBs</p>
            </div>
            <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-2xl p-6 text-center">
                <div class="w-12 h-12 bg-green-400/20 rounded-full flex items-center justify-center mx-auto mb-3">
                    <span class="text-green-400 font-bold">L</span>
                </div>
                <h3 class="text-2xl font-bold">â€”</h3>
                <p class="text-[var(--text-secondary)] text-sm">Max Levels</p>
            </div>
            <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-2xl p-6 text-center">
                <div class="w-12 h-12 bg-orange-400/20 rounded-full flex items-center justify-center mx-auto mb-3">
                    <span class="text-orange-400 font-bold">%</span>
                </div>
                <h3 class="text-2xl font-bold">â€”</h3>
                <p class="text-[var(--text-secondary)] text-sm">Network Growth (30d)</p>
            </div>
        </div>
    </div>
</div>
