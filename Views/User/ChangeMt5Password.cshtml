@{
    ViewData["Title"] = "Change Crib Password";
}
<div class="custome-scroll min-h-screen bg-primary text-[var(--text-primary)] p-8">
    <div class="w-full space-y-8">
        <div>
            <h1 class="text-2xl font-bold text-[var(--text-primary)]">Change Crib Password</h1>
            <p class="text-[var(--text-secondary)]">Select a client, pick a Crib account, and update passwords.</p>
        </div>

        <div class="bg-white border border-[var(--border-secondary)] rounded-sm p-8 shadow-xl">
            <form class="grid grid-cols-1 lg:grid-cols-2 gap-4 relative">
                <!-- Client -->
                <div class="space-y-2">
                    <label class="text-[var(--text-primary)] text-sm font-medium mb-1">Client</label>
                    <input type="text" placeholder="Search Client" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-2 px-3 text-sm outline-none focus:ring-2 focus:ring-[var(--button-primary-bg)]" />
                </div>

                <!-- Account -->
                <div class="space-y-2">
                    <label class="text-[var(--text-primary)] text-sm font-medium mb-1">Crib Account <span class="text-[var(--accent)]">*</span></label>
                    <select class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-2 px-3 text-sm outline-none focus:ring-2 focus:ring-[var(--button-primary-bg)]">
                        <option>No accounts available</option>
                    </select>
                </div>

                <!-- Password -->
                <div class="space-y-2">
                    <label class="text-[var(--text-primary)] text-sm font-medium mb-1">Password</label>
                    <input type="password" placeholder="Enter Password" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-2 px-3 text-sm outline-none focus:ring-2 focus:ring-[var(--button-primary-bg)]" />
                </div>

                <!-- Actions -->
                <div class="col-span-full mt-4 flex gap-4 pt-4">
                    <button type="button" class="bg-[var(--button-primary-bg)] hover:opacity-90 text-[var(--button-primary-text)] px-6 py-2 rounded-sm text-sm font-semibold ">
                        Update Password
                    </button>
                    <button type="button" class="border border-[var(--border-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] bg-transparent px-4 py-2 rounded-sm text-sm font-semibold">
                        Reset
                    </button>
                </div>
            </form>
        </div>

        <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-2xl p-6">
            <h3 class="text-lg font-semibold text-[var(--text-primary)] mb-3">Password Change Information</h3>
            <ul class="space-y-2 text-[var(--text-secondary)] text-sm">
                <li>â€¢ Password changes take effect immediately.</li>
                <li>â€¢ Re-login to Crib with your new password(s).</li>
                <li>â€¢ Do not share your passwords.</li>
                <li>â€¢ Contact support if you face any issues.</li>
            </ul>
        </div>
    </div>
