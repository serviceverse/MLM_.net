@{
    ViewData["Title"] = "IB Application";
}

<div class="p-4 md:p-8">
    <div class="max-w-4xl space-y-6">
        <h1 class="text-3xl font-bold text-[var(--text-primary)] tracking-tight">IB Application</h1>

        @if (ViewBag.Status == "APPROVED")
        {
            <div class="bg-green-50/80 border border-green-200 rounded-2xl p-6 shadow-sm">
                <p class="text-green-700 font-bold flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    You are already an approved IB.
                </p>
            </div>
        }
        else if (ViewBag.Status == "REJECTED")
        {
            <div class="bg-red-50/80 border border-red-200 rounded-2xl p-6 shadow-sm space-y-2">
                <p class="text-red-700 font-bold flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    Your IB request was rejected.
                </p>
                <p class="text-sm text-red-600 font-medium">Reason: @ViewBag.RejectionReason</p>
                <button class="mt-2 border border-red-300 text-red-700 bg-[var(--bg-primary)] hover:bg-red-50 px-4 py-2 rounded-lg text-sm font-semibold transition-colors shadow-sm">
                    Re-Apply
                </button>
            </div>
        }
        else if (ViewBag.Status == "PENDING")
        {
            <div class="bg-yellow-50/80 border border-yellow-200 rounded-2xl p-6 shadow-sm">
                <p class="text-yellow-700 font-bold flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Your IB request is under review.
                </p>
            </div>
        }
        else
        {
            <!-- Eligibility Note -->
            <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-2xl shadow-sm">
                <div class="p-6 md:p-8 space-y-3">
                    <h2 class="text-xl font-bold text-[var(--text-primary)]">Eligibility</h2>
                    <p class="text-[var(--text-secondary)] leading-relaxed">
                        To qualify as an Introducing Broker (IB), you must have at least
                        <span class="font-bold text-[var(--text-primary)]">5 clients</span> associated with your account.
                        <br />
                        <span class="text-sm mt-3 block text-[var(--text-secondary)] font-medium bg-[var(--bg-tertiary)] p-3 rounded-xl border border-[var(--border-secondary)]">
                            💡 <span class="font-semibold text-[var(--text-primary)]">Tip:</span> Focus on inviting genuine, active clients. Strong client relationships and consistent activity improve your approval chances.
                        </span>
                    </p>
                </div>
            </div>

            <!-- Application Form -->
            <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-2xl shadow-sm mt-6">
                <div class="p-6 md:p-8 space-y-4">
                    <form class="space-y-5">
                        <div>
                            <label class="block text-[var(--text-primary)] font-bold mb-2">Why do you want to become an IB?</label>
                            <textarea 
                                rows="4"
                                placeholder="Share your experience, growth plan, and how you’ll support referred clients…"
                                class="w-full p-4 rounded-xl border border-[var(--border-secondary)] bg-[var(--bg-primary)] text-[var(--text-primary)] placeholder-gray-400 focus:outline-none focus:border-[#4f46e5] focus:ring-2 focus:ring-[#4f46e5]/20 resize-y shadow-sm transition-all"></textarea>
                        </div>
                        <button type="submit" class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-white font-semibold py-3 px-8 rounded-xl shadow-md shadow-[var(--button-primary-bg)]/20 transition-all">
                            Submit IB Request
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
