@{
    ViewData["Title"] = "Resend Verification Email";
}
<div class="custome-scroll min-h-screen bg-primary text-[var(--text-primary)] p-8">
    <div class="w-full space-y-8">
        <div>
            <h1 class="text-2xl font-bold text-[var(--text-primary)]">Resend Verification Email</h1>
            <p class="text-[var(--text-secondary)]">Search a user and resend their account verification email.</p>
        </div>

        <div class="bg-white border border-[var(--border-secondary)] rounded-sm p-8 space-y-4">
            <div class="space-y-2">
                <label class="text-[var(--text-primary)] text-sm font-medium mb-1">Client</label>
                <input type="text" placeholder="Search Client" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-2 px-3 text-sm outline-none focus:ring-2 focus:ring-[var(--button-primary-bg)]" />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="space-y-1">
                    <label class="text-[var(--text-primary)]">Full Name</label>
                    <input disabled class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-md py-2 px-3 opacity-50" />
                </div>
                <div class="space-y-1">
                    <label class="text-[var(--text-primary)]">Email</label>
                    <input disabled class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-md py-2 px-3 opacity-50" />
                </div>
                <div class="space-y-1">
                    <label class="text-[var(--text-primary)]">Contact No</label>
                    <input disabled class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-md py-2 px-3 opacity-50" />
                </div>
            </div>

            <div class="flex gap-3 pt-4">
                <button class="bg-[var(--button-primary-bg)] hover:opacity-90 text-[var(--button-primary-text)] px-6 py-2 rounded-sm text-sm font-semibold flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    Resend Verification
                </button>
                <button class="border border-[var(--border-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] bg-transparent px-4 py-2 rounded-sm text-sm font-semibold">
                    Clear
                </button>
            </div>

            <p class="text-xs text-[var(--text-tertiary)]">
                Tip: If the user canâ€™t find the email, ask them to check spam/promotions or add your support address to contacts.
            </p>
        </div>
    </div>
