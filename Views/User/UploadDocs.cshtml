@{
    ViewData["Title"] = "Upload KYC";
}
<div class="p-6 md:p-8">
    <div class="max-w-6xl space-y-6">
        <div>
            <h1 class="text-3xl font-bold">Upload KYC (Admin)</h1>
            <p class="text-[var(--text-secondary)]">Search a client and upload POI / POA on their behalf.</p>
        </div>

        <div class="bg-[var(--bg-secondary)] border border-[var(--border-secondary)] rounded-3xl p-6 space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="space-y-2">
                    <label class="text-sm font-medium">Client</label>
                    <input type="text" placeholder="Search client..." class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] rounded-lg py-3 px-3 outline-none focus:ring-2 focus:ring-[var(--button-primary-bg)]" />
                </div>
                <div class="space-y-2">
                    <label class="text-sm text-[var(--text-secondary)]">Selected Client ID</label>
                    <input type="text" readonly class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] rounded-lg py-3 px-3 outline-none opacity-70" />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- POI -->
                <div class="p-6 rounded-2xl border-2 border-dashed border-[var(--border-secondary)] hover:border-[var(--button-primary-bg)]/50 transition-colors">
                    <div class="flex flex-col items-center space-y-4 text-center">
                        <div class="relative">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-[var(--text-tertiary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19A4.5 4.5 0 0 0 18 10h-1.26A8 8 0 1 0 3 16.3"/><path d="m16 16-4-4-4 4"/><path d="M12 12v9"/></svg>
                        </div>
                        <div>
                            <div class="text-lg">Proof of Identity (POI)</div>
                            <div class="text-xs text-[var(--text-tertiary)]">JPEG, PNG, or PDF</div>
                        </div>
                        <label class="text-[var(--button-primary-bg)] hover:text-[var(--button-primary-hover-bg)] cursor-pointer underline">
                            Browse
                            <input type="file" accept=".jpeg,.jpg,.png,.pdf" class="hidden" />
                        </label>
                        <button class="bg-[var(--button-primary-bg)] hover:opacity-90 text-[var(--button-primary-text)] px-8 py-3 rounded-xl font-semibold w-full mt-4">
                            Upload POI
                        </button>
                    </div>
                </div>

                <!-- POA -->
                <div class="p-6 rounded-2xl border-2 border-dashed border-[var(--border-secondary)] hover:border-[var(--button-primary-bg)]/50 transition-colors">
                    <div class="flex flex-col items-center space-y-4 text-center">
                        <div class="relative">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-[var(--text-tertiary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19A4.5 4.5 0 0 0 18 10h-1.26A8 8 0 1 0 3 16.3"/><path d="m16 16-4-4-4 4"/><path d="M12 12v9"/></svg>
                        </div>
                        <div>
                            <div class="text-lg">Proof of Address (POA)</div>
                            <div class="text-xs text-[var(--text-tertiary)]">JPEG, PNG, or PDF</div>
                        </div>
                        <label class="text-[var(--button-primary-bg)] hover:text-[var(--button-primary-hover-bg)] cursor-pointer underline">
                            Browse
                            <input type="file" accept=".jpeg,.jpg,.png,.pdf" class="hidden" />
                        </label>
                        <button class="bg-[var(--button-primary-bg)] hover:opacity-90 text-[var(--button-primary-text)] px-8 py-3 rounded-xl font-semibold w-full mt-4">
                            Upload POA
                        </button>
                    </div>
                </div>
            </div>

            <p class="text-xs text-[var(--text-tertiary)]">
                Uploading sets that document’s status to <b>PENDING</b> and clears any previous rejection reason.
            </p>
        </div>
    </div>
</div>
