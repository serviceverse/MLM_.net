@{
    ViewData["Title"] = "KYC Verification";
}

<div class="min-h-screen bg-primary text-[var(--text-primary)] p-8">
    <div class="max-w-4xl mx-auto space-y-8">
        <div>
            <h1 class="text-4xl font-bold text-[var(--text-primary)] mb-2">Identity Verification</h1>
            <p class="text-[var(--text-secondary)]">Please submit your Proof of Identity (POI) and Proof of Address (POA).</p>
        </div>
        <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-3xl p-8 text-center text-[var(--text-tertiary)]">
            <h3 class="text-2xl font-bold mb-4">Upload Documents</h3>
            <p>File upload forms for POI and POA will be integrated here.</p>
        </div>
    </div>
</div>
