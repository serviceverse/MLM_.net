@{
    ViewData["Title"] = "KYC Verification";
}

<div class="p-6 md:p-8">
    <div class="max-w-6xl space-y-4">
        <div>
            <h1 class="text-2xl font-bold text-[var(--text-primary)]">Identity Verification</h1>
            <p class="text-[var(--text-secondary)]">Please submit your Proof of Identity (POI) and Proof of Address (POA).</p>
        </div>
        <div class="bg-white border border-[var(--border-secondary)] rounded-sm p-8 text-center text-[var(--text-tertiary)]">
            <h3 class="text-2xl font-bold mb-4">Upload Documents</h3>
            <p>File upload forms for POI and POA will be integrated here.</p>
        </div>
    </div>
</div>
