@{
    ViewData["Title"] = "Bank Details";
}
<div class="p-6 md:p-8">
    <div class="max-w-6xl space-y-6">
        <!-- Header -->
        <!-- Header & Action Bar -->
        <div class="mb-6">
            <div>
                <h1 class="text-2xl font-bold">Add Bank Details</h1>
                <p class="text-sm text-[var(--text-secondary)] mt-1">Provide your banking information for account verification</p>
            </div>
            <!-- Action items will go here -->
        </div>

        <!-- Form -->
        <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-xl shadow-sm p-6 md:p-8">
            <form class="flex-1 flex flex-col">
                <!-- Row 1 -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="space-y-2">
                        <label class="font-medium">Account Holder's Name <span class="text-red-400">*</span></label>
                        <input type="text" placeholder="Enter Account Holder's Name" class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-3 px-4 outline-none" required />
                    </div>

                    <div class="space-y-2">
                        <label class="font-medium">Account No. <span class="text-red-400">*</span></label>
                        <input type="text" placeholder="Enter account number" class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-3 px-4 outline-none" required />
                    </div>

                    <div class="space-y-2">
                        <label class="font-medium">IFSC/Swift Code <span class="text-red-400">*</span></label>
                        <input type="text" placeholder="Enter ifsc/swift code" class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-3 px-4 outline-none" required />
                    </div>
                </div>

                <!-- Row 2 -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="space-y-2">
                        <label class="font-medium">IBAN No.</label>
                        <input type="text" placeholder="Enter iban number" class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-3 px-4 outline-none" />
                    </div>

                    <div class="space-y-2">
                        <label class="font-medium">Bank Name <span class="text-red-400">*</span></label>
                        <input type="text" placeholder="Enter bank name" class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-3 px-4 outline-none" required />
                    </div>

                    <div class="space-y-2">
                        <label class="font-medium">Bank Address</label>
                        <input type="text" placeholder="Enter bank address" class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-3 px-4 outline-none" />
                    </div>
                </div>

                <!-- Row 3 -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="space-y-2">
                        <label class="font-medium">Country <span class="text-red-400">*</span></label>
                        <select class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-3 px-4 outline-none" required>
                            <option value="">Please Choose...</option>
                            <option value="United States">United States</option>
                            <option value="United Kingdom">United Kingdom</option>
                            <option value="Canada">Canada</option>
                            <option value="Australia">Australia</option>
                            <option value="India">India</option>
                        </select>
                    </div>

                    <div class="space-y-2">
                        <label class="font-medium">Bank Book <span class="text-red-400">*</span></label>
                        <div class="relative">
                            <input type="file" accept=".pdf,.jpg,.jpeg,.png" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" required />
                            <div class="bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] hover:border-[var(--button-primary-bg)] rounded-xl py-3 px-4 flex items-center justify-between transition-colors">
                                <div class="col-span-full mt-4 flex items-center space-x-3">
                                    <button type="button" class="bg-[var(--button-secondary-bg)] hover:bg-[var(--button-secondary-hover-bg)] text-[var(--button-secondary-text)] px-3 py-1 rounded text-sm">Choose File</button>
                                    <span class="text-[var(--text-tertiary)] text-sm">No file chosen</span>
                                </div>
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--text-tertiary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
                            </div>
                        </div>
                        <p class="text-xs text-[var(--text-tertiary)]">Supported: PDF, JPG, PNG. Max 5MB.</p>
                    </div>
                </div>

                <!-- Submit -->
                <div class="col-span-full mt-4 flex justify-start">
                    <button type="submit" class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] hover:text-[var(--button-primary-hover-text)] px-8 py-3 rounded-xl font-semibold">
                        Submit
                    </button>
                </div>
            </form>
        </div>

        <!-- Info Section -->
        <div class="bg-[var(--bg-secondary)]/30 border border-[var(--border-primary)] rounded-2xl p-6">
            <h3 class="text-lg font-semibold mb-3">Important Information</h3>
            <ul class="space-y-2 text-[var(--text-secondary)] text-sm">
                <li>• Ensure all bank details are accurate to avoid processing delays</li>
                <li>• The account name should match your registered trading account name</li>
                <li>• Upload a clear copy of your bank statement or passbook</li>
                <li>• Processing time for bank verification is typically 1-2 business days</li>
            </ul>
        </div>
    </div>
</div>
