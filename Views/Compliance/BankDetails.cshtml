@{
    ViewData["Title"] = "Bank Details";
}
<div class="p-4 md:p-8 space-y-6">
    <!-- Header -->
    <div class="mb-2">
        <h1 class="text-3xl font-bold text-[var(--text-primary)] tracking-tight">Add Bank Details</h1>
        <p class="text-sm text-[var(--text-secondary)] mt-1 font-medium">Provide your banking information for account verification</p>
    </div>

    <!-- Form -->
    <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-2xl shadow-sm p-6 md:p-8">
        <form class="flex-1 flex flex-col space-y-6">
            <!-- Row 1 -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="space-y-2">
                    <label class="font-bold text-[var(--text-primary)]">Account Holder's Name <span class="text-red-500">*</span></label>
                    <input type="text" placeholder="Enter Account Holder's Name" class="w-full bg-[var(--bg-primary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-2 focus:ring-[var(--button-primary-bg)]/20 rounded-xl py-3 px-4 outline-none shadow-sm transition-all" required />
                </div>

                <div class="space-y-2">
                    <label class="font-bold text-[var(--text-primary)]">Account No. <span class="text-red-500">*</span></label>
                    <input type="text" placeholder="Enter account number" class="w-full bg-[var(--bg-primary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-2 focus:ring-[var(--button-primary-bg)]/20 rounded-xl py-3 px-4 outline-none shadow-sm transition-all" required />
                </div>

                <div class="space-y-2">
                    <label class="font-bold text-[var(--text-primary)]">IFSC/Swift Code <span class="text-red-500">*</span></label>
                    <input type="text" placeholder="Enter ifsc/swift code" class="w-full bg-[var(--bg-primary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-2 focus:ring-[var(--button-primary-bg)]/20 rounded-xl py-3 px-4 outline-none shadow-sm transition-all" required />
                </div>
            </div>

            <!-- Row 2 -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="space-y-2">
                    <label class="font-bold text-[var(--text-primary)]">IBAN No.</label>
                    <input type="text" placeholder="Enter iban number" class="w-full bg-[var(--bg-primary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-2 focus:ring-[var(--button-primary-bg)]/20 rounded-xl py-3 px-4 outline-none shadow-sm transition-all" />
                </div>

                <div class="space-y-2">
                    <label class="font-bold text-[var(--text-primary)]">Bank Name <span class="text-red-500">*</span></label>
                    <input type="text" placeholder="Enter bank name" class="w-full bg-[var(--bg-primary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-2 focus:ring-[var(--button-primary-bg)]/20 rounded-xl py-3 px-4 outline-none shadow-sm transition-all" required />
                </div>

                <div class="space-y-2">
                    <label class="font-bold text-[var(--text-primary)]">Bank Address</label>
                    <input type="text" placeholder="Enter bank address" class="w-full bg-[var(--bg-primary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-2 focus:ring-[var(--button-primary-bg)]/20 rounded-xl py-3 px-4 outline-none shadow-sm transition-all" />
                </div>
            </div>

            <!-- Row 3 -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="space-y-2">
                    <label class="font-bold text-[var(--text-primary)]">Country <span class="text-red-500">*</span></label>
                    <select class="w-full bg-[var(--bg-primary)] border border-[var(--border-secondary)] text-[var(--text-primary)] focus:border-[var(--button-primary-bg)] focus:ring-2 focus:ring-[var(--button-primary-bg)]/20 rounded-xl py-3 px-4 outline-none shadow-sm transition-all" required>
                        <option value="">Please Choose...</option>
                        <option value="United States">United States</option>
                        <option value="United Kingdom">United Kingdom</option>
                        <option value="Canada">Canada</option>
                        <option value="Australia">Australia</option>
                        <option value="India">India</option>
                    </select>
                </div>

                <div class="space-y-2">
                    <label class="font-bold text-[var(--text-primary)]">Bank Book <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <input type="file" accept=".pdf,.jpg,.jpeg,.png" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" required />
                        <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] focus-within:border-[var(--button-primary-bg)] focus-within:ring-2 focus-within:ring-[var(--button-primary-bg)]/20 rounded-xl py-2 px-4 flex items-center justify-between shadow-sm transition-all min-h-[50px]">
                            <div class="flex items-center space-x-3 w-full">
                                <button type="button" class="bg-[var(--bg-tertiary)] hover:bg-[var(--border-secondary)] text-[var(--text-secondary)] border border-[var(--border-secondary)] px-3 py-1.5 rounded-lg text-sm font-semibold transition-colors">Choose File</button>
                                <span class="text-[var(--text-tertiary)] text-sm font-medium truncate">No file chosen</span>
                            </div>
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--text-tertiary)] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
                        </div>
                    </div>
                    <p class="text-xs text-[var(--text-tertiary)] font-medium">Supported: PDF, JPG, PNG. Max 5MB.</p>
                </div>
            </div>

            <!-- Submit -->
            <div class="pt-4 flex justify-start">
                <button type="submit" class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] hover:text-[var(--button-primary-hover-text)] px-8 py-3 rounded-xl font-bold shadow-md shadow-[var(--button-primary-bg)]/20 transition-all">
                    Submit Details
                </button>
            </div>
        </form>
    </div>

    <!-- Info Section -->
    <div class="bg-blue-50/50 border border-blue-100 rounded-2xl p-6 shadow-sm">
        <h3 class="text-lg font-bold text-blue-900 mb-3">Important Information</h3>
        <ul class="space-y-2 text-blue-800 font-medium text-sm">
            <li class="flex items-start"><span class="mr-2 text-blue-500">•</span> Ensure all bank details are accurate to avoid processing delays</li>
            <li class="flex items-start"><span class="mr-2 text-blue-500">•</span> The account name should match your registered trading account name</li>
            <li class="flex items-start"><span class="mr-2 text-blue-500">•</span> Upload a clear copy of your bank statement or passbook</li>
            <li class="flex items-start"><span class="mr-2 text-blue-500">•</span> Processing time for bank verification is typically 1-2 business days</li>
        </ul>
    </div>
</div>
