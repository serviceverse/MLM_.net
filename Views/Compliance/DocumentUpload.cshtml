@{
    ViewData["Title"] = "Document Upload";
}
<div class="p-4 md:p-8 space-y-4">
    <!-- Header -->
    <div class="mb-2">
        <h1 class="text-2xl font-bold text-[var(--text-primary)] tracking-tight">Upload Document List</h1>
        <p class="text-sm text-[var(--text-secondary)] mt-1 font-medium">Manage your trading account verification documents</p>
    </div>

    <!-- Upload Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <!-- POA Card -->
        <div class="bg-white border border-[var(--border-secondary)] rounded-sm shadow-sm p-6 md:p-8 flex flex-col transition-all hover:shadow-md">
            <h2 class="text-xl font-bold text-[var(--text-primary)] mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                Proof of Address (POA) 
                <span class="text-xs bg-[var(--bg-tertiary)] text-[var(--text-secondary)] px-3 py-1 rounded-full font-medium border border-[var(--border-secondary)]">Aadhar Card</span>
            </h2>
            <div class="border-2 border-dashed border-[var(--border-secondary)] hover:border-[var(--button-primary-bg)] hover:bg-[var(--button-primary-bg)]/5 rounded-2xl p-10 text-center transition-all duration-300 flex-grow flex items-center justify-center">
                <div class="flex flex-col items-center space-y-4">
                    <div class="w-16 h-16 bg-[var(--bg-tertiary)] rounded-full flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[var(--text-secondary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>
                    </div>
                    <div class="space-y-2">
                        <p class="text-[var(--text-primary)] text-sm font-medium mb-1">
                            Drag & drop files or 
                            <label class="text-[var(--button-primary-bg)] hover:underline cursor-pointer">
                                Browse
                                <input type="file" multiple accept=".jpeg,.jpg,.png,.pdf" class="hidden" />
                            </label>
                        </p>
                        <p class="text-xs text-[var(--text-tertiary)] font-medium">Supported formats: JPEG, JPG, PNG, PDF</p>
                    </div>
                </div>
            </div>
            <div class="mt-6 flex justify-center">
                <button class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] px-6 py-2 rounded-sm text-sm font-semibold shadow-md shadow-[var(--button-primary-bg)]/20 transition-all w-full sm:w-auto">
                    UPLOAD FILES
                </button>
            </div>
        </div>

        <!-- POI Card -->
        <div class="bg-white border border-[var(--border-secondary)] rounded-sm shadow-sm p-6 md:p-8 flex flex-col transition-all hover:shadow-md">
            <h2 class="text-xl font-bold text-[var(--text-primary)] mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                Proof of Identity (POI) 
                <span class="text-xs bg-[var(--bg-tertiary)] text-[var(--text-secondary)] px-3 py-1 rounded-full font-medium border border-[var(--border-secondary)]">Driving License, Pancard</span>
            </h2>
            <div class="border-2 border-dashed border-[var(--border-secondary)] hover:border-[var(--button-primary-bg)] hover:bg-[var(--button-primary-bg)]/5 rounded-2xl p-10 text-center transition-all duration-300 flex-grow flex items-center justify-center">
                <div class="flex flex-col items-center space-y-4">
                    <div class="w-16 h-16 bg-[var(--bg-tertiary)] rounded-full flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[var(--text-secondary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>
                    </div>
                    <div class="space-y-2">
                        <p class="text-[var(--text-primary)] text-sm font-medium mb-1">
                            Drag & drop files or 
                            <label class="text-[var(--button-primary-bg)] hover:underline cursor-pointer">
                                Browse
                                <input type="file" multiple accept=".jpeg,.jpg,.png,.pdf" class="hidden" />
                            </label>
                        </p>
                        <p class="text-xs text-[var(--text-tertiary)] font-medium">Supported formats: JPEG, JPG, PNG, PDF</p>
                    </div>
                </div>
            </div>
            <div class="mt-6 flex justify-center">
                <button class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] px-6 py-2 rounded-sm text-sm font-semibold shadow-md shadow-[var(--button-primary-bg)]/20 transition-all w-full sm:w-auto">
                    UPLOAD FILES
                </button>
            </div>
        </div>
    </div>

    <!-- KYC Status Section -->
    <div class="bg-white border border-[var(--border-secondary)] rounded-sm shadow-sm overflow-hidden flex flex-col mt-6">
        
        <div class="p-5 border-b border-[var(--border-secondary)] flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-[var(--bg-primary)]">
            <div class="flex space-x-6">
                <button class="pb-1 border-b-2 border-[var(--button-primary-bg)] text-[var(--text-primary)] font-bold">Pending (0)</button>
                <button class="pb-1 border-b-2 border-transparent text-[var(--text-secondary)] hover:text-[var(--text-primary)] font-medium transition-colors">Approved (0)</button>
                <button class="pb-1 border-b-2 border-transparent text-[var(--text-secondary)] hover:text-[var(--text-primary)] font-medium transition-colors">Rejected (0)</button>
            </div>

            <div class="relative w-full sm:w-80">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 absolute left-3 top-1/2 transform -translate-y-1/2 text-[var(--text-tertiary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input type="text" placeholder="Search by document type..." class="pl-10 w-full bg-[var(--bg-primary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)]/20 rounded-lg py-2 outline-none text-sm shadow-sm transition-all" />
            </div>
        </div>

        <div class="overflow-x-auto bg-[var(--bg-primary)]">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-[var(--border-secondary)] bg-[var(--bg-tertiary)]">
                        @foreach (var heading in new[] { "Serial No.", "Document Type", "Document", "Status", "Submitted Date", "Comments" })
                        {
                            <th class="py-3 px-5 text-xs text-left text-[var(--text-secondary)] font-semibold uppercase tracking-wider">@heading</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="6" class="text-center py-12">
                            <div class="flex flex-col items-center space-y-3">
                                <div class="w-12 h-12 bg-[var(--bg-tertiary)] rounded-full flex items-center justify-center border border-[var(--border-secondary)]">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[var(--text-tertiary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                                </div>
                                <p class="text-[var(--text-tertiary)] text-sm font-medium">No pending KYC documents found</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
