@model MLM.Models.Users

@{
    Layout = null;
    ViewData["Title"] = "Register";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - TheCubeFactory</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            margin: 0;
            padding: 0;
        }

        html, body {
            height: 100%;
            background: #ffffff;
            color: #0f172a;
        }

        .auth-page {
            display: flex;
            min-height: 100vh;
            width: 100%;
        }

        /* --- LEFT SIDE: FORM --- */
        .auth-left {
            flex: 0 0 50%;
            display: flex;
            flex-direction: column;
            padding: 40px 60px;
            background: #ffffff;
            position: relative;
            z-index: 10;
        }

        .brand-area {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .brand-icon {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 3px;
            width: 28px;
            height: 28px;
        }

        .brand-icon span {
            background: #4f46e5;
            border-radius: 3px;
        }

        .brand-icon span:nth-child(2) { opacity: 0.8; }
        .brand-icon span:nth-child(3) { opacity: 0.6; }
        .brand-icon span:nth-child(4) { opacity: 0.4; }

        .brand-name {
            font-size: 20px;
            font-weight: 700;
            color: #0f172a;
            letter-spacing: -0.5px;
        }

        .form-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 40px 0;
        }

        .form-box {
            width: 100%;
            max-width: 400px;
        }

        .form-title {
            font-size: 34px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 10px;
            letter-spacing: -1px;
        }

        .form-subtitle {
            color: #64748b;
            font-size: 16px;
            margin-bottom: 28px;
        }

        .input-group-custom {
            margin-bottom: 16px;
        }

        .form-label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: #334155;
            margin-bottom: 6px;
        }

        .form-control {
            width: 100%;
            height: 48px;
            border-radius: 10px;
            border: 1px solid #cbd5e1;
            background: #fff;
            font-size: 15px;
            padding: 0 16px;
            color: #0f172a;
            transition: all 0.2s ease;
            box-shadow: 0 1px 2px rgba(0,0,0,0.03);
        }

        .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15);
            outline: none;
        }

        .field-error {
            display: block;
            font-size: 13px;
            color: #ef4444;
            margin-top: 4px;
        }

        .btn-login {
            width: 100%;
            height: 48px;
            border: none;
            border-radius: 10px;
            background: #4f46e5;
            color: #ffffff;
            font-size: 16px;
            font-weight: 600;
            transition: all 0.2s ease;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.2), 0 2px 4px -1px rgba(79, 70, 229, 0.1);
            margin-top: 24px;
        }

        .btn-login:hover {
            background: #4338ca;
            transform: translateY(-1px);
            box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.25), 0 4px 6px -2px rgba(79, 70, 229, 0.15);
        }

        .bottom-text {
            text-align: center;
            color: #64748b;
            margin-top: 36px;
            font-size: 15px;
        }

        .bottom-text a {
            color: #4f46e5;
            font-weight: 600;
            text-decoration: none;
        }

        .bottom-text a:hover {
            text-decoration: underline;
        }

        .alert {
            border-radius: 10px;
            font-size: 14px;
            padding: 14px 16px;
            margin-bottom: 24px;
            border: 1px solid transparent;
        }

        .alert-error, .alert-danger {
            background-color: #fef2f2;
            border-color: #fecaca;
            color: #991b1b;
        }

        .alert-success {
            background-color: #f0fdf4;
            border-color: #bbf7d0;
            color: #166534;
        }


        /* --- RIGHT SIDE: PREMIUM ILLUSTRATION --- */
        .auth-right {
            flex: 0 0 50%;
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        /* Abstract shapes */
        .shape {
            position: absolute;
            filter: blur(80px);
            border-radius: 50%;
            opacity: 0.6;
            animation: drift 15s infinite alternate ease-in-out;
        }

        .shape-1 {
            width: 400px;
            height: 400px;
            background: #ec4899;
            top: -100px;
            right: -50px;
        }

        .shape-2 {
            width: 500px;
            height: 500px;
            background: #3b82f6;
            bottom: -150px;
            left: -100px;
            animation-delay: -5s;
        }

        @@keyframes drift {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(40px, -40px) scale(1.1); }
        }

        .glass-panel {
            position: relative;
            z-index: 2;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 32px;
            padding: 48px;
            width: 80%;
            max-width: 480px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.3);
            color: #ffffff;
        }

        .glass-icon {
            width: 64px;
            height: 64px;
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 32px;
        }

        .glass-icon svg {
            width: 32px;
            height: 32px;
            color: #ffffff;
        }

        .glass-title {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 16px;
            letter-spacing: -0.5px;
            line-height: 1.2;
        }

        .glass-subtitle {
            font-size: 16px;
            line-height: 1.6;
            color: rgba(255, 255, 255, 0.85);
            margin-bottom: 40px;
        }

        /* Mock UI Elements inside glass panel */
        .mock-ui {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .mock-bar {
            height: 12px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 6px;
            position: relative;
            overflow: hidden;
        }

        .mock-bar::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            background: linear-gradient(90deg, rgba(255,255,255,0.4), rgba(255,255,255,0.9));
            border-radius: 6px;
            width: var(--width);
        }

        .mock-row {
            display: flex;
            gap: 16px;
            margin-top: 8px;
        }

        .mock-card {
            flex: 1;
            height: 60px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* Responsive */
        @@media (max-width: 992px) {
            .auth-right {
                display: none;
            }
            .auth-left {
                flex: 0 0 100%;
                padding: 40px 24px;
            }
        }

        @@media (max-width: 576px) {
            .form-title {
                font-size: 28px;
            }
            .auth-left {
                padding: 24px 20px;
            }
            .form-wrapper {
                padding: 20px 0;
                justify-content: flex-start;
            }
        }
    </style>
</head>

<body>
    <main class="auth-page">
        <!-- Left Side: Form -->
        <section class="auth-left">
            <div class="brand-area">
                <div class="brand-icon">
                    <span></span><span></span><span></span><span></span>
                </div>
                <div class="brand-name">TheCubeFactory</div>
            </div>

            <div class="form-wrapper">
                <div class="form-box">
                    <h1 class="form-title">Create an account</h1>
                    <p class="form-subtitle">Please fill in your details to sign up</p>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-error">
                            @ViewBag.Error
                        </div>
                    }

                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success">
                            @ViewBag.Success
                        </div>
                    }

                    <form asp-action="RegisteUser" asp-controller="Auth" method="post">
                        @Html.AntiForgeryToken()

                        <div class="input-group-custom">
                            <label asp-for="Name" class="form-label">Full Name</label>
                            <input asp-for="Name" type="text" class="form-control" autocomplete="name" placeholder="John Doe" />
                            <span asp-validation-for="Name" class="field-error"></span>
                        </div>

                        <div class="input-group-custom">
                            <label asp-for="Email" class="form-label">Email address</label>
                            <input asp-for="Email" type="email" class="form-control" autocomplete="email" placeholder="name@company.com" />
                            <span asp-validation-for="Email" class="field-error"></span>
                        </div>

                        <div class="input-group-custom">
                            <label asp-for="Phone" class="form-label">Phone Number</label>
                            <input asp-for="Phone" type="text" class="form-control" autocomplete="tel" placeholder="+1 (555) 000-0000" />
                            <span asp-validation-for="Phone" class="field-error"></span>
                        </div>

                        <div class="input-group-custom">
                            <label asp-for="Password" class="form-label">Password</label>
                            <input asp-for="Password" type="password" class="form-control" autocomplete="new-password" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="field-error"></span>
                        </div>

                        <button type="submit" class="btn-login">
                            Create Account
                        </button>
                    </form>

                    <p class="bottom-text">
                        Already registered?
                        <a asp-controller="Auth" asp-action="Login">Login here</a>
                    </p>
                </div>
            </div>
        </section>

        <!-- Right Side: Premium Illustration -->
        <section class="auth-right">
            <div class="shape shape-1"></div>
            <div class="shape shape-2"></div>

            <div class="glass-panel">
                <div class="glass-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
                    </svg>
                </div>
                <h2 class="glass-title">Supercharge Your Business</h2>
                <p class="glass-subtitle">Connect, manage, and scale your MLM network seamlessly with our powerful, intuitive dashboard built for modern teams.</p>
                
                <div class="mock-ui">
                    <div class="mock-bar" style="--width: 85%;"></div>
                    <div class="mock-bar" style="--width: 60%;"></div>
                    <div class="mock-bar" style="--width: 95%;"></div>
                    <div class="mock-row">
                        <div class="mock-card"></div>
                        <div class="mock-card"></div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>