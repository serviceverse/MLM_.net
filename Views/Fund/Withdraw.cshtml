@{
    ViewData["Title"] = "Withdraw";
}
<div class="p-6 md:p-8">
    <div class="max-w-6xl space-y-4">
        <!-- Header -->
        <!-- Header & Action Bar -->
        <div class="mb-6">
            <div>
                <h1 class="text-2xl font-bold">Withdraw</h1>
                <p class="text-sm text-[var(--text-secondary)] mt-1">Choose your preferred withdraw method to move funds from your wallet or trading account</p>
            </div>
            <!-- Action items will go here -->
        </div>

        <!-- Withdrawal Type Selection -->
        <div class="bg-[var(--bg-secondary)]/30 border border-[var(--border-primary)] rounded-2xl p-6 space-y-4">
            <div class="space-y-2">
                <label class="text-lg font-semibold block">Withdrawal Type <span class="text-red-500">*</span></label>
                <select class="w-full rounded-sm py-2 px-3 text-sm bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] outline-none">
                    <option value="">Please Choose...</option>
                    <option value="WALLET">Wallet</option>
                    <option value="ACCOUNT">Account</option>
                </select>
            </div>
        </div>

        <!-- Payment Methods Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <!-- USDT -->
            <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] hover:bg-[var(--bg-tertiary)] hover:shadow-xl transition-all duration-300 rounded-3xl p-6 flex flex-col justify-between h-full group">
                <div class="space-y-4 flex-1">
                    <div class="flex justify-center items-center h-12">
                        <img src="https://genova-uploads.s3.ap-south-1.amazonaws.com/mt5/projectImages/visa_mastercard.png" alt="USDT" class="object-contain h-10" />
                    </div>
                    <h3 class="text-lg font-semibold text-center">Withdraw with USDT</h3>
                    <p class="text-sm text-[var(--text-tertiary)] text-center">Fast crypto Withdraws with Tether</p>
                </div>
                <button class="w-full mt-6 bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] py-2 rounded-sm text-sm font-semibold shadow-lg group-hover:shadow-[var(--button-primary-bg)]/20 transition-all duration-300">
                    Withdraw Now
                </button>
            </div>

            <!-- Bank Transfer -->
            <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] hover:bg-[var(--bg-tertiary)] hover:shadow-xl transition-all duration-300 rounded-3xl p-6 flex flex-col justify-between h-full group">
                <div class="space-y-4 flex-1">
                    <div class="flex justify-center items-center h-12">
                        <img src="https://genova-uploads.s3.ap-south-1.amazonaws.com/mt5/projectImages/bank_transfer.png" alt="Bank" class="object-contain h-10" />
                    </div>
                    <h3 class="text-lg font-semibold text-center">Withdraw with Bank Transfer</h3>
                    <p class="text-sm text-[var(--text-tertiary)] text-center">Secure bank wire transfers</p>
                </div>
                <button class="w-full mt-6 bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] py-2 rounded-sm text-sm font-semibold shadow-lg group-hover:shadow-[var(--button-primary-bg)]/20 transition-all duration-300">
                    Withdraw Now
                </button>
            </div>

            <!-- Cash -->
            <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] hover:bg-[var(--bg-tertiary)] hover:shadow-xl transition-all duration-300 rounded-3xl p-6 flex flex-col justify-between h-full group">
                <div class="space-y-4 flex-1">
                    <div class="flex justify-center items-center h-12">
                        <img src="https://genova-uploads.s3.ap-south-1.amazonaws.com/mt5/projectImages/cash.png" alt="Cash" class="object-contain h-10" />
                    </div>
                    <h3 class="text-lg font-semibold text-center">Withdraw with Cash</h3>
                    <p class="text-sm text-[var(--text-tertiary)] text-center">Cash Withdraw at authorized locations</p>
                </div>
                <button class="w-full mt-6 bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] py-2 rounded-sm text-sm font-semibold shadow-lg group-hover:shadow-[var(--button-primary-bg)]/20 transition-all duration-300">
                    Withdraw Now
                </button>
            </div>
        </div>
    </div>
</div>
