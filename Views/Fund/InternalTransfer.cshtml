@{
    ViewData["Title"] = "Internal Transfer";
}
<div class="p-6 md:p-8">
    <div class="max-w-6xl space-y-6">
        <!-- Header -->
        <!-- Header & Action Bar -->
        <div class="mb-6">
            <div>
                <h1 class="text-2xl font-bold">Internal Transfer</h1>
                <p class="text-sm text-[var(--text-secondary)] mt-1">Transfer funds between your trading accounts</p>
            </div>
            <!-- Action items will go here -->
        </div>

        <!-- Transfer Form -->
        <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-xl shadow-sm p-6 md:p-8">
            <form class="grid grid-cols-1 lg:grid-cols-2 gap-6 relative">
                <!-- From Account -->
                <div class="space-y-2">
                    <label class="font-medium block">From Account <span class="text-red-400">*</span></label>
                    <select class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-3 px-4 outline-none">
                        <option value="">Please Choose...</option>
                    </select>
                </div>

                <!-- Arrow -->
                <div class="flex justify-center">
                    <div class="bg-[var(--accent-success)]/20 p-3 rounded-full relative w-12 h-12 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[var(--accent-success)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m16 3 4 4-4 4"/><path d="M20 7H4"/><path d="m8 21-4-4 4-4"/><path d="M4 17h16"/></svg>
                    </div>
                </div>

                <!-- To Account -->
                <div class="space-y-2">
                    <label class="font-medium block">To Account <span class="text-red-400">*</span></label>
                    <select class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-3 px-4 outline-none">
                        <option value="">Please Choose...</option>
                    </select>
                </div>

                <!-- Amount -->
                <div class="space-y-2">
                    <label class="font-medium block">Amount <span class="text-red-400">*</span></label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 transform -translate-y-1/2 text-[var(--text-tertiary)]">$</span>
                        <input type="number" step="0.01" min="0" placeholder="Enter amount" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-3 pl-8 px-4 outline-none" required />
                    </div>
                </div>

                <!-- Submit Button -->
                <div class="col-span-full mt-4 flex justify-start pt-4">
                    <button type="submit" class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] px-8 py-3 rounded-xl font-semibold">
                        Submit
                    </button>
                </div>
            </form>
        </div>

        <!-- Transfer Info -->
        <div class="bg-[var(--bg-secondary)]/30 border border-[var(--border-primary)] rounded-2xl p-6">
            <h3 class="text-lg font-semibold mb-3">Transfer Information</h3>
            <ul class="space-y-2 text-[var(--text-secondary)] text-sm">
                <li>• Transfers between your accounts are instant and free</li>
                <li>• Minimum transfer amount: $1.00</li>
                <li>• You can transfer between any of your verified accounts</li>
                <li>• Transfer history is available in your account dashboard</li>
            </ul>
        </div>
    </div>
</div>
