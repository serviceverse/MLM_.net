@{
    ViewData["Title"] = "Wallet History Report";
}
<div class="p-2 md:p-4">
    
        <!-- Header -->
        <div>
            <h1 class="text-2xl font-bold text-[var(--text-primary)]">Wallet History Report</h1>
            <p class="text-[var(--text-secondary)]">Review and analyze wallet transactions with advanced filtering</p>
        </div>

        <!-- Filter Section -->
        <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-3xl p-6">
            <div class="flex flex-wrap items-end gap-4">
                <div class="space-y-2">
                    <label class="text-[var(--text-tertiary)] font-medium">From:</label>
                    <input type="date" class="bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] p-2 rounded outline-none" />
                </div>
                <div class="space-y-2">
                    <label class="text-[var(--text-tertiary)] font-medium">To:</label>
                    <input type="date" class="bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] p-2 rounded outline-none" />
                </div>
                <button class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] hover:text-[var(--button-primary-hover-text)] font-semibold px-6 py-2 rounded-xl">
                    Search
                </button>
            </div>
        </div>

        <!-- Data/Table Section -->
        <div class="flex-1 overflow-hidden flex flex-col">
            <div class="flex items-center justify-between mb-6">
                <!-- Entries per page and Export -->
                <div class="flex items-center space-x-4">
                    <div class="flex items-center space-x-2">
                        <span class="text-[var(--text-secondary)]">Show</span>
                        <select class="w-20 bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] p-2 rounded outline-none">
                            <option>10</option>
                        </select>
                        <span class="text-[var(--text-secondary)]">entries</span>
                    </div>
                    <button class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] px-4 py-2 rounded-xl font-semibold flex items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                        Export CSV
                    </button>
                </div>

                <!-- Search bar -->
                <div class="flex items-center space-x-2">
                    <span class="text-[var(--text-secondary)]">Search:</span>
                    <div class="relative">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--text-tertiary)] absolute left-3 top-1/2 transform -translate-y-1/2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                        <input type="text" placeholder="Search transactions..." class="pl-10 bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] py-2 pr-3 rounded outline-none" />
                    </div>
                </div>
            </div>

            <!-- Table -->
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-[var(--border-secondary)] hover:bg-[var(--bg-tertiary)] even:bg-[var(--bg-secondary)]/40 transition-none">
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">ID</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Client Name</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Client Email</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Crib ID</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Method</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Amount</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Note</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Status</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="9" class="py-8 text-center text-[var(--text-tertiary)]">
                                No data available
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Pagination & info -->
            <div class="flex items-center justify-between mt-6">
                <div class="text-[var(--text-secondary)]">Showing 0 to 0 of 0 entries</div>
                <div class="flex items-center space-x-2">
                    <button disabled class="border border-[var(--border-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] bg-transparent px-3 py-1 rounded text-sm opacity-50 cursor-not-allowed">Previous</button>
                    <button disabled class="border border-[var(--border-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] bg-transparent px-3 py-1 rounded text-sm opacity-50 cursor-not-allowed">Next</button>
                </div>
            </div>
        </div>
    </div>
</div>
