@{
    ViewData["Title"] = "IB Withdraw Report";
}
<div class="p-6 md:p-8">
    <div class="page-scroll-content px-8 py-6">
        
            <!-- Header -->
            <div>
                <h1 class="text-2xl font-bold text-[var(--text-primary)]">IB Withdraw Report</h1>
                <p class="text-[var(--text-secondary)]">Review all IB withdrawal requests and statuses</p>
            </div>

            <!-- Filters -->
            <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-3xl p-6 flex flex-wrap items-end gap-4">
                <div class="space-y-2">
                    <label class="text-[var(--text-primary)] font-medium">From:</label>
                    <input type="date" class="bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] p-2 rounded outline-none" />
                </div>
                <div class="space-y-2">
                    <label class="text-[var(--text-primary)] font-medium">To:</label>
                    <input type="date" class="bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] p-2 rounded outline-none" />
                </div>
                <button class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] hover:text-[var(--button-primary-hover-text)] font-semibold px-6 py-2 rounded-xl">
                    Search
                </button>
            </div>

            <!-- Table -->
            <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-3xl">
                <div class="flex items-center justify-between mb-6 px-8 pt-8">
                    <div class="flex items-center space-x-4"></div>
                    <div class="flex items-center space-x-2">
                        <label class="text-[var(--text-primary)] font-medium">Search:</label>
                        <input type="text" placeholder="Search client" class="bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-md py-1 px-3 outline-none" />
                    </div>
                </div>

                <div class="p-8 overflow-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-[var(--border-primary)] uppercase font-semibold text-left">
                                <th class="px-4 py-2 text-[var(--text-secondary)]">Client Id</th>
                                <th class="px-4 py-2 text-[var(--text-secondary)]">Name</th>
                                <th class="px-4 py-2 text-[var(--text-secondary)]">Withdraw To</th>
                                <th class="px-4 py-2 text-[var(--text-secondary)]">Amount</th>
                                <th class="px-4 py-2 text-[var(--text-secondary)]">Payment Method</th>
                                <th class="px-4 py-2 text-[var(--text-secondary)]">Note</th>
                                <th class="px-4 py-2 text-[var(--text-secondary)]">Comment</th>
                                <th class="px-4 py-2 text-[var(--text-secondary)]">Status</th>
                                <th class="px-4 py-2 text-[var(--text-secondary)]">Date</th>
                                <th class="px-4 py-2 text-[var(--text-secondary)]">Modified Date</th>
                                <th class="px-4 py-2 text-[var(--text-secondary)]">Marketing Name</th>
                                <th class="px-4 py-2 text-[var(--text-secondary)]">Approved/Rejected By</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="12" class="text-center text-[var(--text-secondary)] py-6">No data available</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
