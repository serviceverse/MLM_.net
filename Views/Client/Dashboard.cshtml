@model MLM.Models.DashboardViewModel
@{
    ViewData["Title"] = "Client Dashboard";
}

<div class="min-h-screen bg-primary text-[var(--text-primary)] p-6 lg:p-8">
    <div class="w-full">
        
        <!-- Top bar -->
        <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between mb-6">
            <h1 class="text-3xl lg:text-4xl font-bold tracking-tight">Hello, @Model.UserName ðŸ‘‹</h1>
            <div class="flex items-center gap-2">
            </div>
        </div>

        <!-- Row 1: Hero + Right rail -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-8">
            
            <!-- Hero: Your Asset -->
            <div class="lg:col-span-2 rounded-3xl bg-[var(--bg-secondary)] border border-[var(--border-primary)] overflow-hidden shadow-lg transform transition-all hover:shadow-xl hover:-translate-y-0.5">
                <div class="p-6 pb-2 border-b border-[var(--border-primary)]">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-xl bg-[var(--button-primary-bg)]/20 flex items-center justify-center">
                            <svg class="w-5 h-5 text-[var(--button-primary-bg)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"></path></svg>
                        </div>
                        <h3 class="text-xl font-semibold leading-none tracking-tight">Your Asset</h3>
                    </div>
                </div>

                <div class="p-6 grid gap-4 lg:grid-cols-3">
                    <!-- Big balance -->
                    <div class="lg:col-span-2 rounded-2xl p-6 bg-gradient-to-br from-[var(--bg-tertiary)]/40 via-[var(--bg-secondary)] to-[var(--bg-tertiary)] border border-[var(--border-primary)] shadow-md flex flex-col">
                        <div class="flex items-start justify-between mb-6">
                            <div>
                                <p class="text-sm text-[var(--text-secondary)]">Total Equity</p>
                                <p class="text-4xl font-extrabold mt-1">
                                    @Model.WalletBalance.ToString("N2") @Model.Currency
                                </p>
                            </div>
                            <div class="flex gap-2">
                                <a href="/fund/withdraw" class="rounded-md bg-[var(--button-primary-bg)] text-[var(--button-primary-text)] hover:bg-[var(--button-primary-hover-bg)] text-sm px-4 py-2 flex items-center gap-1">Withdraw</a>
                                <a href="/fund/deposits" class="rounded-md bg-[var(--button-primary-bg)] text-[var(--button-primary-text)] hover:bg-[var(--button-primary-hover-bg)] text-sm px-4 py-2 flex items-center gap-1">Deposit</a>
                            </div>
                        </div>

                        <div class="flex-grow"></div>

                        <!-- Cards positioned at the bottom -->
                        <div class="grid grid-cols-2 gap-3 text-sm mt-auto">
                            <div class="rounded-xl px-4 py-3 bg-[var(--bg-secondary)]/60 border border-[var(--border-primary)] shadow-sm">
                                <p class="text-[var(--text-secondary)]">Accounts</p>
                                <p class="text-xl font-semibold">@Model.AccountCount</p>
                            </div>
                            <div class="rounded-xl px-4 py-3 bg-[var(--bg-secondary)]/60 border border-[var(--border-primary)] shadow-sm">
                                <p class="text-[var(--text-secondary)]">Total Deposit</p>
                                <p class="text-xl font-semibold">@Model.TotalDeposits.ToString("N2") @Model.Currency</p>
                            </div>
                            <div class="rounded-xl px-4 py-3 bg-[var(--bg-secondary)]/60 border border-[var(--border-primary)] shadow-sm">
                                <p class="text-[var(--text-secondary)]">Total Withdraw</p>
                                <p class="text-xl font-semibold">@Model.TotalWithdrawals.ToString("N2") @Model.Currency</p>
                            </div>
                            <div class="rounded-xl px-4 py-3 bg-[var(--bg-secondary)]/60 border border-[var(--border-primary)] shadow-sm">
                                <p class="text-[var(--text-secondary)]">Performance (24h)</p>
                                <p class="flex items-center gap-1 text-green-400 font-semibold">
                                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg> +0.00%
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Right column: IB Overview + Referral -->
                    <div class="flex flex-col gap-4">
                        <div class="rounded-2xl p-6 bg-[var(--bg-tertiary)]/60 border border-[var(--border-primary)] shadow-md">
                            <div class="flex items-center gap-2 mb-2">
                                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="M7 15v2"></path><path d="M11 11v6"></path><path d="M15 7v10"></path></svg>
                                <p class="font-semibold">IB Overview</p>
                            </div>
                            <div class="space-y-3 text-sm">
                                <div class="flex items-center justify-between">
                                    <span class="text-[var(--text-secondary)]">Available Commission</span>
                                    <span class="font-semibold">@Model.IbAvailable.ToString("N2") @Model.Currency</span>
                                </div>
                                <div class="flex items-center justify-between">
                                    <span class="text-[var(--text-secondary)]">Withdrawn</span>
                                    <span class="font-semibold">@Model.IbWithdrawn.ToString("N2") @Model.Currency</span>
                                </div>
                                <div class="flex items-center justify-between">
                                    <span class="text-[var(--text-secondary)]">Total Clients</span>
                                    <span class="font-semibold">@Model.IbTotalClients</span>
                                </div>
                            </div>
                        </div>

                        @if (Model.ShowReferral)
                        {
                            <div class="rounded-2xl p-6 bg-[var(--bg-tertiary)]/60 border border-[var(--border-primary)] shadow-md">
                                <div class="flex items-center gap-2 mb-3">
                                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                                    <p class="font-semibold">Referral</p>
                                </div>
                                <div class="space-y-2 text-sm">
                                    <div class="rounded-xl p-3 bg-[var(--bg-secondary)]/60 border border-[var(--border-primary)] shadow-sm">
                                        <p class="text-[var(--text-secondary)]">Your Code</p>
                                        <p class="font-semibold text-lg">@(string.IsNullOrEmpty(Model.ReferralCode) ? "â€”" : Model.ReferralCode)</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Right rail widgets -->
            <div class="space-y-4">
                <div class="rounded-2xl bg-[var(--bg-secondary)] border border-[var(--border-primary)] shadow-lg transform transition-all hover:shadow-xl hover:-translate-y-0.5">
                    <div class="p-5 text-center">
                        <div class="w-10 h-10 mx-auto rounded-xl bg-[var(--button-primary-bg)]/20 flex items-center justify-center mb-2">
                            <svg class="w-5 h-5 text-[var(--button-primary-bg)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"></path><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"></path><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"></path></svg>
                        </div>
                        <p class="text-sm text-[var(--text-secondary)]">Wallet Balance</p>
                        <p class="text-2xl font-bold mt-1">@Model.WalletBalance.ToString("N2") @Model.Currency</p>
                    </div>
                </div>

                <div class="rounded-2xl bg-[var(--bg-secondary)] border border-[var(--border-primary)] shadow-lg transform transition-all hover:shadow-xl hover:-translate-y-0.5">
                    <div class="p-5 text-center">
                        <div class="w-10 h-10 mx-auto rounded-xl bg-[var(--button-primary-bg)]/20 flex items-center justify-center mb-2">
                            <svg class="w-5 h-5 text-[var(--button-primary-bg)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                        </div>
                        <p class="text-sm text-[var(--text-secondary)]">Total Crib Accounts</p>
                        <p class="text-4xl font-extrabold mt-1 text-[var(--button-primary-bg)]">@Model.AccountCount</p>
                    </div>
                </div>

                <!-- Trending Assets SVG Placeholder -->
            </div>
        </div>

    </div>
</div>
