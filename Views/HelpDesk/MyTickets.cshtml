@{
    ViewData["Title"] = "My Tickets";
}
<div class="p-2 md:p-4">
    
        <!-- Page Header -->
    <div class="mb-2 flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-[var(--text-primary)]">My Tickets</h1>
            <p class="text-sm text-[var(--text-secondary)] mt-1">View and manage your support tickets</p>
        </div>
        <a href="/HelpDesk/NewTicket" class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] px-4 py-2 rounded-sm text-sm font-semibold inline-flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                Create New Ticket
            </a>
    </div>

        <!-- Tickets Table -->
        <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-sm shadow-none">
                <!-- Tabs -->
                <div class="mb-6 border-b border-[var(--border-secondary)]">
                    <button class="bg-[var(--button-primary-bg)] text-black px-4 py-2 font-semibold rounded-t-lg">
                        Open Tickets
                    </button>
                    <button class="text-[var(--text-primary)] px-4 py-2 hover:bg-[var(--bg-tertiary)] rounded-t-lg transition-colors">
                        Closed Tickets
                    </button>
                </div>

                <!-- Controls -->
                <div class="px-3 py-2 border-b border-[var(--border-secondary)] flex flex-wrap items-center justify-between gap-4">
                <div class="flex items-center space-x-2">
                    <span class="text-[var(--text-secondary)]">Show</span>
                        <select class="bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] rounded-lg py-1 px-2 outline-none">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                        <span class="text-[var(--text-secondary)]">entries</span>
                    </div>

                    <div class="flex items-center space-x-2">
                        <span class="text-[var(--text-secondary)]">Search:</span>
                        <div class="relative">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--text-tertiary)] absolute left-3 top-1/2 transform -translate-y-1/2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                            <input type="text" placeholder="Search tickets..." class="pl-10 bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-lg py-2 outline-none" />
                        </div>
                    </div>
                </div>

                <!-- Table -->
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-[var(--border-secondary)] hover:bg-[var(--bg-tertiary)] even:bg-[var(--bg-secondary)]/40 transition-none">
                                <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Serial No.</th>
                                <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Enquiry Type</th>
                                <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Ticket ID</th>
                                <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Title</th>
                                <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Priority</th>
                                <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Status</th>
                                <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Last Updated</th>
                                <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Mock Data -->
                            <tr class="border-b border-[var(--border-secondary)]/50 hover:bg-[var(--bg-secondary)]/30">
                                <td class="py-4 px-4 text-[var(--text-primary)]">1</td>
                                <td class="py-4 px-4 text-[var(--text-primary)]">DEPOSIT</td>
                                <td class="py-4 px-4 text-[var(--text-primary)] font-mono">TKT-12345</td>
                                <td class="py-4 px-4 text-[var(--text-primary)]">Deposit not received</td>
                                <td class="py-4 px-4">
                                    <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-[var(--badge-warning-bg)] text-[var(--badge-warning-text)] border border-[var(--badge-warning-border)]">High</span>
                                </td>
                                <td class="py-4 px-4">
                                    <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-[var(--badge-error-bg)] text-[var(--badge-error-text)] border border-[var(--badge-error-border)]">Open</span>
                                </td>
                                <td class="py-4 px-4 text-[var(--text-secondary)]">2023-10-27 10:30</td>
                                <td class="py-4 px-4">
                                    <button class="border border-[var(--border-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)] bg-transparent rounded px-3 py-1 flex items-center text-sm">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                                        View
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
        <div class="px-3 py-2 border-t border-[var(--border-secondary)] flex flex-wrap items-center justify-between gap-4">
                    <div class="text-[var(--text-secondary)]">Showing 1 to 1 of 1 entries</div>
                    <div class="flex items-center space-x-2">
                        <button class="border border-[var(--border-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)] bg-transparent rounded px-3 py-1 text-sm inline-flex items-center opacity-50 cursor-not-allowed">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                            Previous
                        </button>
                        <button class="bg-[var(--button-primary-bg)] text-[var(--button-primary-text)] hover:bg-[var(--button-primary-hover-bg)] rounded px-3 py-1 text-sm">1</button>
                        <button class="border border-[var(--border-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)] bg-transparent rounded px-3 py-1 text-sm inline-flex items-center opacity-50 cursor-not-allowed">
                            Next
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
