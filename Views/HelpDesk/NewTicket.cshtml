@{
    ViewData["Title"] = "New Ticket";
}

<div class="p-2 md:p-4 text-[var(--text-primary)]">
    <div class="space-y-6">
        <!-- Page Header (Matches Tickets/Index.cshtml) -->
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-[var(--text-primary)]">Create New Ticket</h1>
                <p class="text-sm text-[var(--text-secondary)] mt-1">Submit a support request and our team will assist you.</p>
            </div>
        </div>

        <!-- Create Ticket Form Card -->
        <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-sm shadow-sm">
            <div class="p-6 md:p-8">
                <form class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Category -->
                    <div class="space-y-2">
                        <label class="text-[var(--text-secondary)] text-sm font-semibold block">
                            Category <span class="text-rose-500">*</span>
                        </label>
                        <div class="relative">
                            <select class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)] rounded-sm py-2.5 px-3 text-sm outline-none appearance-none transition-colors" required>
                                <option value="">Please Choose...</option>
                                <option value="GENERAL">General</option>
                                <option value="ACCOUNT">Account Issue</option>
                                <option value="DEPOSIT">Deposit</option>
                                <option value="WITHDRAW">Withdrawal</option>
                                <option value="KYC">KYC Verification</option>
                                <option value="TECHNICAL">Technical Support</option>
                            </select>
                            <i class="bi bi-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-[var(--text-secondary)] pointer-events-none text-xs"></i>
                        </div>
                    </div>

                    <!-- Priority -->
                    <div class="space-y-2">
                        <label class="text-[var(--text-secondary)] text-sm font-semibold block">
                            Priority <span class="text-rose-500">*</span>
                        </label>
                        <div class="relative">
                            <select class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)] rounded-sm py-2.5 px-3 text-sm outline-none appearance-none transition-colors" required>
                                <option value="">Please Choose...</option>
                                <option value="LOW">Low</option>
                                <option value="MEDIUM">Medium</option>
                                <option value="HIGH">High</option>
                            </select>
                            <i class="bi bi-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-[var(--text-secondary)] pointer-events-none text-xs"></i>
                        </div>
                    </div>

                    <!-- Title -->
                    <div class="space-y-2 md:col-span-2">
                        <label class="text-[var(--text-secondary)] text-sm font-semibold block">
                            Title <span class="text-rose-500">*</span>
                        </label>
                        <input type="text" placeholder="Brief summary of your issue" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)] rounded-sm py-2.5 px-3 text-sm outline-none transition-colors" required />
                    </div>

                    <!-- Description -->
                    <div class="space-y-2 md:col-span-2">
                        <label class="text-[var(--text-secondary)] text-sm font-semibold block">
                            Describe your problem <span class="text-rose-500">*</span>
                        </label>
                        <textarea placeholder="Please provide as much detail as possible to help us resolve your issue quickly..." class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)] rounded-sm py-3 px-3 text-sm outline-none min-h-[160px] resize-y transition-colors" required></textarea>
                    </div>

                    <!-- Attachment -->
                    <div class="space-y-2 md:col-span-2">
                        <label class="text-[var(--text-secondary)] text-sm font-semibold block">
                            Attachment <span class="text-[var(--text-tertiary)] font-normal">(optional)</span>
                        </label>
                        <div class="flex items-center justify-center w-full">
                            <label for="dropzone-file" class="flex flex-col items-center justify-center w-full h-32 border-2 border-[var(--border-secondary)] border-dashed rounded-sm cursor-pointer bg-[var(--bg-tertiary)] hover:bg-[var(--bg-secondary)] transition-colors">
                                <div class="flex flex-col items-center justify-center pt-5 pb-6">
                                    <i class="bi bi-cloud-arrow-up text-2xl text-[var(--text-secondary)] mb-2"></i>
                                    <p class="mb-1 text-sm text-[var(--text-secondary)]"><span class="font-semibold text-[var(--button-primary-bg)]">Click to upload</span> or drag and drop</p>
                                    <p class="text-xs text-[var(--text-tertiary)]">PNG, JPG or PDF (MAX. 5MB)</p>
                                </div>
                                <input id="dropzone-file" type="file" accept="image/png,image/jpeg,application/pdf" class="hidden" />
                            </label>
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <div class="md:col-span-2 mt-4 pt-6 border-t border-[var(--border-secondary)] flex justify-end">
                        <button type="submit" class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] px-8 py-2.5 rounded-sm text-sm font-semibold flex items-center transition-colors">
                            <i class="bi bi-send mr-2"></i> Submit Ticket
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Information Panel -->
        <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-sm shadow-sm">
            <div class="p-6">
                <div class="flex items-center gap-2 mb-4">
                    <i class="bi bi-info-circle text-[var(--button-primary-bg)] text-xl"></i>
                    <h3 class="text-lg font-bold text-[var(--text-primary)]">What happens next?</h3>
                </div>
                <ul class="space-y-3 text-[var(--text-secondary)] text-sm ml-2">
                    <li class="flex items-start"><i class="bi bi-check2 text-emerald-500 mr-3 mt-0.5 text-lg"></i> You will receive a confirmation email with your ticket number.</li>
                    <li class="flex items-start"><i class="bi bi-check2 text-emerald-500 mr-3 mt-0.5 text-lg"></i> Our support team will review your ticket within 2-4 hours.</li>
                    <li class="flex items-start"><i class="bi bi-check2 text-emerald-500 mr-3 mt-0.5 text-lg"></i> You will be notified via email when there are updates to your ticket.</li>
                    <li class="flex items-start"><i class="bi bi-check2 text-emerald-500 mr-3 mt-0.5 text-lg"></i> You can track the progress of your ticket in the "My Tickets" section.</li>
                </ul>
            </div>
        </div>
    </div>
</div>
