@{
    ViewData["Title"] = "Reports Dashboard";
}
<div class="min-h-screen bg-gradient-to-br from-gray-900 via-gray-800 to-black text-white p-8">
    <div class="flex-1 flex flex-col">
        <!-- Header -->
        <div class="text-center space-y-4">
            <h1 class="text-4xl font-bold text-white mb-2">Reports Dashboard</h1>
            <p class="text-gray-300 text-lg">Access comprehensive reports for your trading activities</p>
        </div>

        <!-- Quick Stats -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div class="bg-gray-800/50 border border-gray-700 rounded-2xl p-6 text-center">
                <div class="w-12 h-12 bg-lime-400/20 rounded-full flex items-center justify-center mx-auto mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-lime-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                </div>
                <h3 class="text-2xl font-bold text-white">$12,450</h3>
                <p class="text-gray-400 text-sm">Total Deposits</p>
            </div>

            <div class="bg-gray-800/50 border border-gray-700 rounded-2xl p-6 text-center">
                <div class="w-12 h-12 bg-blue-400/20 rounded-full flex items-center justify-center mx-auto mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                </div>
                <h3 class="text-2xl font-bold text-white">1,247</h3>
                <p class="text-gray-400 text-sm">Total Deals</p>
            </div>

            <div class="bg-gray-800/50 border border-gray-700 rounded-2xl p-6 text-center">
                <div class="w-12 h-12 bg-red-400/20 rounded-full flex items-center justify-center mx-auto mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
                </div>
                <h3 class="text-2xl font-bold text-white">$8,920</h3>
                <p class="text-gray-400 text-sm">Total Withdrawals</p>
            </div>

            <div class="bg-gray-800/50 border border-gray-700 rounded-2xl p-6 text-center">
                <div class="w-12 h-12 bg-purple-400/20 rounded-full flex items-center justify-center mx-auto mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m8 3 4 4-4 4"/><path d="M12 7H4"/><path d="m16 21-4-4 4-4"/><path d="M20 17h-8"/></svg>
                </div>
                <h3 class="text-2xl font-bold text-white">156</h3>
                <p class="text-gray-400 text-sm">Internal Transfers</p>
            </div>
        </div>

        <!-- Reports Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Deposit Report -->
            <div class="bg-gray-800/50 border border-gray-700 hover:bg-gray-700/50 hover:shadow-xl transition-all duration-300 rounded-3xl p-8 group">
                <div class="flex items-start space-x-4">
                    <div class="w-16 h-16 bg-gradient-to-r from-green-400 to-green-600 rounded-2xl flex items-center justify-center text-white shadow-lg shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2" ry="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                    </div>
                    <div class="flex-1 space-y-3">
                        <h3 class="text-xl font-bold text-white group-hover:text-lime-400 transition-colors">Deposit Report</h3>
                        <p class="text-gray-300 leading-relaxed">View all deposit transactions with detailed payment information</p>
                        <a href="/Reports/Deposit" class="bg-lime-400 hover:bg-lime-500 text-gray-900 px-6 py-2 rounded-xl font-semibold shadow-lg inline-flex items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
                            View Report
                        </a>
                    </div>
                </div>
            </div>

            <!-- Deal Report -->
            <div class="bg-gray-800/50 border border-gray-700 hover:bg-gray-700/50 hover:shadow-xl transition-all duration-300 rounded-3xl p-8 group">
                <div class="flex items-start space-x-4">
                    <div class="w-16 h-16 bg-gradient-to-r from-blue-400 to-blue-600 rounded-2xl flex items-center justify-center text-white shadow-lg shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
                    </div>
                    <div class="flex-1 space-y-3">
                        <h3 class="text-xl font-bold text-white group-hover:text-lime-400 transition-colors">Deal Report</h3>
                        <p class="text-gray-300 leading-relaxed">Analyze trading deals, profits, and trading performance</p>
                        <a href="/Reports/Deal" class="bg-lime-400 hover:bg-lime-500 text-gray-900 px-6 py-2 rounded-xl font-semibold shadow-lg inline-flex items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
                            View Report
                        </a>
                    </div>
                </div>
            </div>

            <!-- Withdraw Report -->
            <div class="bg-gray-800/50 border border-gray-700 hover:bg-gray-700/50 hover:shadow-xl transition-all duration-300 rounded-3xl p-8 group">
                <div class="flex items-start space-x-4">
                    <div class="w-16 h-16 bg-gradient-to-r from-red-400 to-red-600 rounded-2xl flex items-center justify-center text-white shadow-lg shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
                    </div>
                    <div class="flex-1 space-y-3">
                        <h3 class="text-xl font-bold text-white group-hover:text-lime-400 transition-colors">Withdraw Report</h3>
                        <p class="text-gray-300 leading-relaxed">Track all withdrawal requests and their processing status</p>
                        <a href="/Reports/Withdraw" class="bg-lime-400 hover:bg-lime-500 text-gray-900 px-6 py-2 rounded-xl font-semibold shadow-lg inline-flex items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
                            View Report
                        </a>
                    </div>
                </div>
            </div>

            <!-- Internal Transfer Report -->
            <div class="bg-gray-800/50 border border-gray-700 hover:bg-gray-700/50 hover:shadow-xl transition-all duration-300 rounded-3xl p-8 group">
                <div class="flex items-start space-x-4">
                    <div class="w-16 h-16 bg-gradient-to-r from-purple-400 to-purple-600 rounded-2xl flex items-center justify-center text-white shadow-lg shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m8 3 4 4-4 4"/><path d="M12 7H4"/><path d="m16 21-4-4 4-4"/><path d="M20 17h-8"/></svg>
                    </div>
                    <div class="flex-1 space-y-3">
                        <h3 class="text-xl font-bold text-white group-hover:text-lime-400 transition-colors">Internal Transfer Report</h3>
                        <p class="text-gray-300 leading-relaxed">Monitor transfers between your trading accounts</p>
                        <a href="/Reports/InternalTransfer" class="bg-lime-400 hover:bg-lime-500 text-gray-900 px-6 py-2 rounded-xl font-semibold shadow-lg inline-flex items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
                            View Report
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Additional Info -->
        <div class="bg-gray-800/30 border border-gray-700 rounded-2xl p-6">
            <h3 class="text-lg font-semibold text-white mb-4">Report Features</h3>
            <div class="grid md:grid-cols-3 gap-4">
                <div>
                    <h4 class="font-medium text-lime-400 mb-2 flex items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        Date Filtering
                    </h4>
                    <p class="text-gray-300 text-sm">Filter reports by custom date ranges to analyze specific periods</p>
                </div>
                <div>
                    <h4 class="font-medium text-lime-400 mb-2 flex items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
                        Export Options
                    </h4>
                    <p class="text-gray-300 text-sm">Export reports to Excel or PDF for offline analysis and record keeping</p>
                </div>
                <div>
                    <h4 class="font-medium text-lime-400 mb-2 flex items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                        Real-time Data
                    </h4>
                    <p class="text-gray-300 text-sm">All reports show real-time data updated automatically</p>
                </div>
            </div>
        </div>
    </div>
</div>
