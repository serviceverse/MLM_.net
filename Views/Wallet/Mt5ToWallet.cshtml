@{
    ViewData["Title"] = "Iman Account To Wallet";
}

<div class="p-4 md:p-8 space-y-4 max-w-4xl mx-auto">
    <!-- Header -->
    <div class="text-center space-y-3 mb-8">
        <div class="w-16 h-16 bg-gradient-to-tr from-[var(--button-primary-bg)] to-indigo-400 rounded-full flex items-center justify-center mx-auto shadow-lg shadow-[var(--button-primary-bg)]/20">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="7" x2="7" y2="17"/><polyline points="17 17 7 17 7 7"/></svg>
        </div>
        <h1 class="text-2xl font-bold text-[var(--text-primary)] tracking-tight">Iman Account To Wallet</h1>
        <p class="text-[var(--text-secondary)] font-medium">Transfer funds from your Iman account to your wallet</p>
    </div>

    <!-- Transfer Form Card -->
    <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-3xl shadow-sm p-6 md:p-10">
        <form class="space-y-4">
            <!-- Select Account -->
            <div class="space-y-2">
                <label class="text-[var(--text-primary)] font-bold">
                    Select Account <span class="text-red-500">*</span>
                </label>
                <select class="w-full bg-[var(--bg-primary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-2 px-3 text-sm outline-none shadow-sm focus:border-[var(--button-primary-bg)] focus:ring-2 focus:ring-[var(--button-primary-bg)]/20 transition-all font-medium appearance-none" required>
                    <option value="">Please Choose...</option>
                    @if (ViewBag.Accounts != null)
                    {
                        foreach (var acc in ViewBag.Accounts)
                        {
                            <option value="@acc.Id">Account #@acc.Id (@acc.Name) - $@acc.Balance.ToString("0.00")</option>
                        }
                    }
                </select>
            </div>

            <!-- Amount -->
            <div class="space-y-2">
                <label class="text-[var(--text-primary)] font-bold">
                    Amount <span class="text-red-500">*</span>
                </label>
                <div class="relative">
                    <span class="absolute left-4 top-1/2 transform -translate-y-1/2 text-[var(--text-secondary)] font-bold">$</span>
                    <input type="number" step="0.01" min="0" placeholder="Enter amount" class="w-full bg-[var(--bg-primary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] rounded-sm py-2 px-3 text-sm pl-8 pr-4 outline-none shadow-sm focus:border-[var(--button-primary-bg)] focus:ring-2 focus:ring-[var(--button-primary-bg)]/20 transition-all font-medium" required />
                </div>
            </div>

            <!-- Note -->
            <div class="space-y-2">
                <label class="text-[var(--text-primary)] font-bold">
                    Note <span class="text-red-500">*</span>
                </label>
                <input type="text" placeholder="Enter Note" class="w-full bg-[var(--bg-primary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] rounded-sm py-2 px-3 text-sm outline-none shadow-sm focus:border-[var(--button-primary-bg)] focus:ring-2 focus:ring-[var(--button-primary-bg)]/20 transition-all font-medium" required />
            </div>

            <!-- Submit -->
            <div class="pt-4">
                <button type="submit" class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] px-8 py-3.5 rounded-xl font-bold shadow-md shadow-[var(--button-primary-bg)]/20 transition-all w-full sm:w-auto flex items-center justify-center">
                    Submit Transfer
                </button>
            </div>
        </form>
    </div>

    <!-- Info Card -->
    <div class="bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] rounded-sm p-4 md:p-6">
        <h3 class="text-lg font-bold text-[var(--text-primary)] mb-3 flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2 text-[var(--button-primary-bg)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            Transfer Information
        </h3>
        <ul class="space-y-2 text-[var(--text-secondary)] font-medium text-sm">
            <li class="flex items-start"><span class="mr-2 text-[var(--button-primary-bg)]">Ã¢â‚¬Â¢</span> Transfers from Iman to wallet are instant and free</li>
            <li class="flex items-start"><span class="mr-2 text-[var(--button-primary-bg)]">Ã¢â‚¬Â¢</span> Minimum transfer amount: $1.00</li>
            <li class="flex items-start"><span class="mr-2 text-[var(--button-primary-bg)]">Ã¢â‚¬Â¢</span> Funds will be available in your wallet immediately</li>
            <li class="flex items-start"><span class="mr-2 text-[var(--button-primary-bg)]">Ã¢â‚¬Â¢</span> You can only transfer available balance from your Iman account</li>
        </ul>
    </div>
</div>
