@{
    ViewData["Title"] = "Wallet History";
}

<div class="p-4 md:p-8 space-y-4">
    <!-- Header -->
    <div class="mb-2">
        <h1 class="text-2xl font-bold text-[var(--text-primary)] tracking-tight">Wallet History Report</h1>
        <p class="text-sm text-[var(--text-secondary)] mt-1 font-medium">View detailed history of all your wallet transactions</p>
    </div>

    <!-- Filter Section -->
    <div class="bg-white border border-[var(--border-secondary)] rounded-sm shadow-sm p-6 md:p-8">
        <div class="flex flex-wrap items-end gap-4">
            <div class="space-y-2">
                <label class="text-[var(--text-secondary)] font-bold">From:</label>
                <input type="date" class="w-full bg-[var(--bg-primary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-xl py-2 px-4 outline-none shadow-sm focus:border-[var(--button-primary-bg)] focus:ring-2 focus:ring-[var(--button-primary-bg)]/20 transition-all" />
            </div>
            <div class="space-y-2">
                <label class="text-[var(--text-secondary)] font-bold">To:</label>
                <input type="date" class="w-full bg-[var(--bg-primary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-xl py-2 px-4 outline-none shadow-sm focus:border-[var(--button-primary-bg)] focus:ring-2 focus:ring-[var(--button-primary-bg)]/20 transition-all" />
            </div>
            <button class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] px-8 py-2.5 rounded-xl font-bold shadow-md shadow-[var(--button-primary-bg)]/20 transition-all">
                Search
            </button>
        </div>
    </div>

    <!-- Table Section -->
    <div class="bg-white border border-[var(--border-secondary)] rounded-sm shadow-sm overflow-hidden flex flex-col">
        <!-- Toolbar -->
        <div class="p-5 border-b border-[var(--border-secondary)] flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-[var(--bg-primary)]">
            <div class="flex items-center space-x-4">
                <div class="flex items-center space-x-2">
                    <span class="text-[var(--text-secondary)] font-medium text-sm">Show</span>
                    <select class="h-9 w-20 rounded-lg border border-[var(--border-secondary)] bg-[var(--bg-primary)] text-[var(--text-primary)] px-2 py-1 text-sm shadow-sm focus:outline-none focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)]/20 transition-all">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                    </select>
                    <span class="text-[var(--text-secondary)] font-medium text-sm">entries</span>
                </div>
                <button class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] px-4 py-1.5 rounded-lg text-sm font-semibold shadow-sm shadow-[var(--button-primary-bg)]/20 transition-all flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                    Export CSV
                </button>
            </div>
            
            <div class="relative w-full sm:w-64">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 absolute left-3 top-1/2 transform -translate-y-1/2 text-[var(--text-tertiary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input type="text" placeholder="Search transactions..." class="pl-10 w-full bg-[var(--bg-primary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)]/20 rounded-lg py-2 outline-none text-sm shadow-sm transition-all" />
            </div>
        </div>

        <!-- Table -->
        <div class="overflow-x-auto bg-[var(--bg-primary)]">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-[var(--border-secondary)] bg-[var(--bg-tertiary)]">
                        @foreach (var heading in new[] { "ID", "Method", "Iman Account", "Amount", "Note", "Status", "Date" })
                        {
                            <th class="py-3 px-5 text-xs text-left text-[var(--text-secondary)] font-bold uppercase tracking-wider">@heading</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.Transactions != null)
                    {
                        foreach (var txn in ViewBag.Transactions)
                        {
                            <tr class="border-b border-[var(--border-secondary)] hover:bg-[var(--bg-tertiary)]/50 transition-colors">
                                <td class="py-4 px-5 text-[var(--text-primary)] font-medium">@txn.Id</td>
                                <td class="py-4 px-5 text-[var(--text-primary)]">@txn.Method</td>
                                <td class="py-4 px-5 text-[var(--text-primary)]">@txn.ImanAccount</td>
                                <td class="py-4 px-5 text-[var(--text-primary)] font-bold">$@txn.Amount.ToString("0.00")</td>
                                <td class="py-4 px-5 text-[var(--text-secondary)]">@txn.Note</td>
                                <td class="py-4 px-5">
                                    @if (txn.Status == "Completed" || txn.Status == "Approved")
                                    {
                                        <span class="bg-green-100 text-green-700 border border-green-200 px-3 py-1 rounded-full text-xs font-bold">@txn.Status</span>
                                    }
                                    else if (txn.Status == "Pending")
                                    {
                                        <span class="bg-yellow-100 text-yellow-700 border border-yellow-200 px-3 py-1 rounded-full text-xs font-bold">@txn.Status</span>
                                    }
                                    else
                                    {
                                        <span class="bg-red-100 text-red-700 border border-red-200 px-3 py-1 rounded-full text-xs font-bold">@txn.Status</span>
                                    }
                                </td>
                                <td class="py-4 px-5 text-[var(--text-secondary)]">@txn.Date.ToString("MMM dd, yyyy HH:mm")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-12 text-[var(--text-tertiary)] font-medium">No transactions found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="p-5 border-t border-[var(--border-secondary)] flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-[var(--bg-primary)]">
            <div class="text-[var(--text-secondary)] text-sm font-medium">
                Showing 1 to 3 of 3 entries
            </div>
            <div class="flex items-center space-x-2">
                <button disabled class="px-4 py-2 border border-[var(--border-secondary)] rounded-lg text-[var(--text-tertiary)] bg-[var(--bg-tertiary)] cursor-not-allowed text-sm font-bold flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                    Previous
                </button>
                <button disabled class="px-4 py-2 border border-[var(--border-secondary)] rounded-lg text-[var(--text-tertiary)] bg-[var(--bg-tertiary)] cursor-not-allowed text-sm font-bold flex items-center">
                    Next
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
            </div>
        </div>
    </div>
</div>
