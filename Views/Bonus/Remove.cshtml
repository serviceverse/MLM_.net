@{
    ViewData["Title"] = "Remove Bonus";
}

<div class="p-2 md:p-4">
    <!-- Page Header -->
    <div class="mb-2 flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-[var(--text-primary)]">Remove Bonus</h1>
            <p class="text-sm text-[var(--text-secondary)] mt-1">Remove active bonuses from users</p>
        </div>
    </div>

    <!-- Card Wrapper -->
    <div class="bg-white border border-[var(--border-secondary)] rounded-sm shadow-none">
        
        <!-- Filters -->
        <div class="px-3 py-2 border-b border-[var(--border-secondary)] flex flex-wrap items-center justify-between gap-4">
            <div class="flex items-center space-x-2">
                <span class="text-[var(--text-secondary)] text-sm">Show</span>
                <select class="h-8 w-16 items-center justify-between rounded-sm border border-[var(--border-secondary)] bg-[var(--bg-tertiary)] px-2 py-1 text-xs ring-offset-background focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 text-[var(--text-primary)]">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
                <span class="text-[var(--text-secondary)] text-sm">entries</span>
            </div>

            <div class="flex items-center space-x-2">
                <span class="text-[var(--text-secondary)] text-sm">Search:</span>
                <div class="relative">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 text-gray-400 absolute left-2 top-1/2 transform -translate-y-1/2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <input type="text" placeholder="Search user or email..." class="flex h-8 w-64 rounded-sm border px-2 py-1 text-xs ring-offset-background pl-7 bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)]" />
                </div>
            </div>
        </div>

        <!-- Table Content -->
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-[var(--border-secondary)] hover:bg-[var(--bg-tertiary)] even:bg-[var(--bg-secondary)]/40 transition-none">
                        @foreach (var heading in new[] { "#", "User", "Email", "Amount", "Reason", "Status", "Action" })
                        {
                            <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold uppercase">
                                @heading
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.ActiveBonuses == null || ((IEnumerable<dynamic>)ViewBag.ActiveBonuses).Count() == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center py-6 text-[12px] text-gray-400">
                                No active bonuses found
                            </td>
                        </tr>
                    }
                    else
                    {
                        int index = 1;
                        foreach (var bonus in ViewBag.ActiveBonuses)
                        {
                            <tr class="border-b border-[var(--border-secondary)] hover:bg-[var(--bg-tertiary)] even:bg-[var(--bg-secondary)]/40 transition-none">
                                <td class="py-1 px-2 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)]">@index</td>
                                <td class="py-1 px-2 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)]">@bonus.User.FullName</td>
                                <td class="py-1 px-2 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)]">@bonus.User.Email</td>
                                <td class="py-1 px-2 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-green-600 font-semibold">$@bonus.Amount</td>
                                <td class="py-1 px-2 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)]">@bonus.Reason</td>
                                <td class="py-1 px-2 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)]">
                                    <span class="inline-flex items-center rounded-sm border px-2.5 py-0.5 text-[10px] font-semibold bg-green-500/20 text-green-600 border-green-500/30">
                                        ACTIVE
                                    </span>
                                </td>
                                <td class="py-1 px-2 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)]">
                                    <button class="bg-red-600 hover:bg-red-700 text-white text-[10px] px-3 py-1 rounded-sm">
                                        Remove
                                    </button>
                                </td>
                            </tr>
                            index++;
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-3 py-2 border-t border-[var(--border-secondary)] flex flex-wrap items-center justify-between gap-4">
            <div class="text-[var(--text-secondary)] text-xs">
                Showing 0 to 0 of 0 entries
            </div>
            <div class="flex items-center space-x-2">
                <button disabled class="inline-flex items-center justify-center rounded-sm text-xs font-medium transition-colors border border-[var(--border-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] bg-transparent h-7 px-2 opacity-50 cursor-not-allowed">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 mr-1"><path d="m15 18-6-6 6-6"/></svg>
                    Previous
                </button>
                <span class="px-2 py-1 text-xs bg-[var(--button-primary-bg)] text-[var(--button-primary-text)] rounded-sm">
                    1 / 1
                </span>
                <button disabled class="inline-flex items-center justify-center rounded-sm text-xs font-medium transition-colors border border-[var(--border-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] bg-transparent h-7 px-2 opacity-50 cursor-not-allowed">
                    Next
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 ml-1"><path d="m9 18 6-6-6-6"/></svg>
                </button>
            </div>
        </div>
    </div>
</div>
