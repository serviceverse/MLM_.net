@{
    ViewData["Title"] = "Bonus List";
}

<div class="p-2 md:p-4">
    <!-- Page Header -->
    <div class="mb-2 flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-[var(--text-primary)]">Bonus List</h1>
            <p class="text-sm text-[var(--text-secondary)] mt-1">List of all bonuses assigned to users</p>
        </div>
    </div>

    <!-- Card Wrapper -->
    <div class="bg-white border border-[var(--border-secondary)] rounded-sm shadow-none">
        
        <!-- Filters -->
        <div class="px-3 py-2 border-b border-[var(--border-secondary)] flex flex-wrap items-center justify-between gap-4">
            <div class="flex items-center space-x-2">
                <span class="text-[var(--text-secondary)] text-sm">Show</span>
                <select id="pageSizeSelect" class="h-8 w-16 items-center justify-between rounded-sm border border-[var(--border-secondary)] bg-[var(--bg-tertiary)] px-2 py-1 text-xs text-[var(--text-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--button-primary-bg)]">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
                <span class="text-[var(--text-secondary)] text-sm">entries</span>
            </div>

            <div class="flex items-center space-x-2">
                <span class="text-[var(--text-secondary)] text-sm">Search:</span>
                <div class="relative">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 text-gray-400 absolute left-2 top-1/2 transform -translate-y-1/2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <input type="text" id="searchInput" placeholder="Search user or email..." class="flex h-8 w-64 rounded-sm border border-[var(--border-secondary)] pl-7 bg-[var(--bg-tertiary)] text-[var(--text-primary)] text-xs placeholder-[var(--text-tertiary)] focus:outline-none focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)]" />
                </div>
            </div>
        </div>

        <!-- Table Content -->
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-[var(--border-secondary)] hover:bg-[var(--bg-tertiary)] even:bg-[var(--bg-secondary)]/40 transition-none">
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold uppercase">#</th>
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold uppercase">User</th>
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold uppercase">Email</th>
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold uppercase">Amount</th>
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold uppercase">Reason</th>
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold uppercase">Status</th>
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-left text-[var(--text-secondary)] font-semibold uppercase">Date</th>
                    </tr>
                </thead>
                <tbody id="bonusTableBody">
                    <tr>
                        <td colspan="7" class="text-center py-6 text-[12px] text-gray-400">Loading…</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-3 py-2 border-t border-[var(--border-secondary)] flex flex-wrap items-center justify-between gap-4">
            <div class="text-[var(--text-secondary)] text-xs" id="paginationInfo">
                Showing 0 to 0 of 0 entries
            </div>
            <div class="flex items-center space-x-2">
                <button id="prevBtn" disabled class="inline-flex items-center justify-center rounded-sm text-xs font-medium transition-colors border border-[var(--border-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] bg-transparent h-7 px-2 disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 mr-1"><path d="m15 18-6-6 6-6"/></svg>
                    Previous
                </button>
                <span id="pageIndicator" class="px-2 py-1 text-xs bg-[var(--button-primary-bg)] text-[var(--button-primary-text)] rounded-sm">
                    1 / 1
                </span>
                <button id="nextBtn" disabled class="inline-flex items-center justify-center rounded-sm text-xs font-medium transition-colors border border-[var(--border-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] bg-transparent h-7 px-2 disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer">
                    Next
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 ml-1"><path d="m9 18 6-6-6-6"/></svg>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            let bonuses = [];
            let search = "";
            let page = 1;
            let pageSize = 10;
            let loading = true;

            const tbody = document.getElementById('bonusTableBody');
            const searchInput = document.getElementById('searchInput');
            const pageSizeSelect = document.getElementById('pageSizeSelect');
            const prevBtn = document.getElementById('prevBtn');
            const nextBtn = document.getElementById('nextBtn');
            const pageIndicator = document.getElementById('pageIndicator');
            const paginationInfo = document.getElementById('paginationInfo');

            async function fetchBonuses() {
                loading = true;
                render();
                try {
                    const response = await fetch('/api/bonus');
                    if (response.ok) {
                        const data = await response.json();
                        bonuses = data || [];
                    } else {
                        bonuses = [];
                    }
                } catch (err) {
                    console.error("Error fetching bonuses:", err);
                    bonuses = [];
                } finally {
                    loading = false;
                    render();
                }
            }

            function render() {
                if (loading) {
                    tbody.innerHTML = `<tr><td colspan="7" class="text-center py-6 text-[12px] text-gray-400">Loading…</td></tr>`;
                    updatePaginationControls(0, 0);
                    return;
                }

                const filtered = bonuses.filter(b => 
                    (b.user?.fullName?.toLowerCase() || "").includes(search.toLowerCase()) ||
                    (b.user?.email?.toLowerCase() || "").includes(search.toLowerCase())
                );

                const total = filtered.length;
                const totalPages = Math.max(1, Math.ceil(total / pageSize));
                
                if (page > totalPages) page = totalPages;
                if (page < 1) page = 1;

                const paginatedData = filtered.slice((page - 1) * pageSize, page * pageSize);

                if (paginatedData.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="7" class="text-center py-6 text-[12px] text-gray-400">No bonus data found</td></tr>`;
                } else {
                    tbody.innerHTML = paginatedData.map((bonus, index) => {
                        const isRemoved = bonus.status === "REMOVED";
                        return \`
                        <tr class="border-b border-[var(--border-secondary)] hover:bg-[var(--bg-tertiary)] even:bg-[var(--bg-secondary)]/40 transition-none">
                            <td class="py-1 px-2 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)]">\${(page - 1) * pageSize + index + 1}</td>
                            <td class="py-1 px-2 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)]">\${bonus.user?.fullName || ""}</td>
                            <td class="py-1 px-2 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)]">\${bonus.user?.email || ""}</td>
                            <td class="py-1 px-2 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-green-600 font-semibold">\$\${bonus.amount}</td>
                            <td class="py-1 px-2 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)]">\${bonus.reason || "—"}</td>
                            <td class="py-1 px-2 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap">
                                <span class="inline-flex items-center rounded-sm border px-2.5 py-0.5 text-[10px] font-semibold \${isRemoved ? 'bg-red-500/20 text-red-600 border-red-500/30' : 'bg-green-500/20 text-green-600 border-green-500/30'}">
                                    \${bonus.status}
                                </span>
                            </td>
                            <td class="py-1 px-2 text-[12px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-primary)]">\${new Date(bonus.createdAt).toLocaleString()}</td>
                        </tr>
                        \`;
                    }).join("");
                }

                updatePaginationControls(paginatedData.length, total, totalPages);
            }

            function updatePaginationControls(currentCount, total, totalPages) {
                if (loading || total === 0) {
                    paginationInfo.textContent = \`Showing 0 to 0 of 0 entries\`;
                    prevBtn.disabled = true;
                    nextBtn.disabled = true;
                    pageIndicator.textContent = \`1 / 1\`;
                    return;
                }

                const start = (page - 1) * pageSize + 1;
                const end = Math.min(page * pageSize, total);
                paginationInfo.textContent = \`Showing \${start} to \${end} of \${total} entries\`;
                
                pageIndicator.textContent = \`\${page} / \${totalPages}\`;
                prevBtn.disabled = page === 1;
                nextBtn.disabled = page === totalPages;
            }

            searchInput.addEventListener('input', (e) => {
                search = e.target.value;
                page = 1;
                render();
            });

            pageSizeSelect.addEventListener('change', (e) => {
                pageSize = Number(e.target.value);
                page = 1;
                render();
            });

            prevBtn.addEventListener('click', () => {
                if (page > 1) {
                    page--;
                    render();
                }
            });

            nextBtn.addEventListener('click', () => {
                const filteredTotal = bonuses.filter(b => 
                    (b.user?.fullName?.toLowerCase() || "").includes(search.toLowerCase()) ||
                    (b.user?.email?.toLowerCase() || "").includes(search.toLowerCase())
                ).length;
                const totalPages = Math.max(1, Math.ceil(filteredTotal / pageSize));
                
                if (page < totalPages) {
                    page++;
                    render();
                }
            });

            fetchBonuses();
        });
    </script>
}
