@{
    ViewData["Title"] = "IB Dashboard";
}

<div class="p-4 md:p-8 space-y-4">
    <div>
        <h1 class="text-2xl font-bold text-[var(--text-primary)] tracking-tight">IB Dashboard</h1>
        <p class="text-[var(--text-secondary)] mt-1">Monitor your IB performance and earnings</p>
    </div>

    <!-- Top Row -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        
        <!-- Monthly Commission Chart Placeholder -->
        <div class="bg-white border border-[var(--border-secondary)] rounded-sm p-6 shadow-sm">
            <div class="flex items-center space-x-2 mb-4">
                <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <h3 class="text-lg font-bold text-[var(--text-primary)]">Monthly Commission</h3>
            </div>
            <div class="h-48 bg-[var(--bg-tertiary)] rounded-xl border border-[var(--border-secondary)] flex items-center justify-center shadow-inner">
                <span class="text-[var(--text-tertiary)] text-sm font-medium">Chart Placeholder</span>
            </div>
        </div>

        <!-- Commission Stats -->
        <div class="bg-white border border-[var(--border-secondary)] rounded-sm p-6 shadow-sm">
            <div class="grid grid-cols-2 gap-4 h-full content-center">
                <div class="text-center">
                    <h3 class="text-3xl font-extrabold text-[var(--text-primary)]">$0</h3>
                    <p class="text-[var(--text-secondary)] text-sm mt-1 font-medium">Withdraw Commission</p>
                </div>
                <div class="text-center">
                    <h3 class="text-3xl font-extrabold text-[var(--text-primary)]">$0</h3>
                    <p class="text-[var(--text-secondary)] text-sm mt-1 font-medium">Available Commission</p>
                </div>
                <div class="text-center mt-4">
                    <h3 class="text-3xl font-extrabold text-[var(--text-primary)]">0</h3>
                    <p class="text-[var(--text-secondary)] text-sm mt-1 font-medium">Total Volume</p>
                </div>
                <div class="text-center mt-4">
                    <h3 class="text-3xl font-extrabold text-[var(--text-primary)]">0</h3>
                    <p class="text-[var(--text-secondary)] text-sm mt-1 font-medium">Total Clients</p>
                </div>
            </div>
        </div>

        <!-- Client Transaction Chart Placeholder -->
        <div class="bg-white border border-[var(--border-secondary)] rounded-sm p-6 shadow-sm">
            <div class="flex items-center space-x-2 mb-4">
                <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                <h3 class="text-lg font-bold text-[var(--text-primary)]">My Client Transaction</h3>
            </div>
            <div class="h-48 bg-[var(--bg-tertiary)] rounded-xl border border-[var(--border-secondary)] flex items-center justify-center shadow-inner">
                <span class="text-[var(--text-tertiary)] text-sm font-medium">Chart Placeholder</span>
            </div>
        </div>
    </div>

    <!-- Status Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        @foreach (var stat in new[] { "KYC", "Live Account", "FTD", "Active Traders & Sub IB" })
        {
            <div class="bg-white border border-[var(--border-secondary)] rounded-sm p-6 shadow-sm hover:shadow-md transition-shadow">
                <h3 class="text-lg font-bold text-[var(--text-primary)] mb-4">@stat</h3>
                <div class="h-24 flex flex-col items-center justify-center">
                    <div class="text-3xl font-extrabold text-[var(--text-primary)] mb-2">0</div>
                    <div class="flex items-center justify-center space-x-4 text-xs font-medium">
                        <div class="flex items-center space-x-1.5">
                            <div class="w-2 h-2 bg-green-500 rounded-full shadow-sm"></div>
                            <span class="text-[var(--text-secondary)]">Complete (0)</span>
                        </div>
                        <div class="flex items-center space-x-1.5">
                            <div class="w-2 h-2 bg-indigo-500 rounded-full shadow-sm"></div>
                            <span class="text-[var(--text-secondary)]">Pending (0)</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Referral & Top Earners -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-4">
        
        <!-- Referral Card -->
        <div class="bg-gradient-to-br from-indigo-50 to-white border border-indigo-100 rounded-2xl p-6 shadow-sm text-center flex flex-col justify-center relative overflow-hidden">
            <!-- Decorative shape -->
            <div class="absolute -top-6 -right-6 w-24 h-24 bg-indigo-100 rounded-full opacity-50 blur-xl"></div>
            
            <div class="w-14 h-14 bg-[var(--bg-primary)] border border-indigo-100 shadow-sm rounded-full flex items-center justify-center mx-auto mb-5 relative z-10">
                <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
            </div>
            <h3 class="text-lg font-bold text-[var(--text-primary)] mb-4 relative z-10">Copy your Referral Link!</h3>
            <button class="bg-indigo-600 hover:bg-indigo-700 text-white py-2.5 px-6 rounded-xl font-semibold shadow-md shadow-indigo-600/20 transition-all relative z-10 w-full sm:w-auto mx-auto">
                Click Here
            </button>
        </div>

        <!-- Top Earners Table (Dense Grid) -->
        <div class="lg:col-span-3 bg-white border border-[var(--border-secondary)] rounded-sm shadow-sm overflow-hidden flex flex-col">
            <div class="px-5 py-4 border-b border-[var(--border-secondary)] flex justify-between items-center bg-[var(--bg-primary)]">
                <h3 class="text-lg font-bold text-[var(--text-primary)]">Top 5 Earnings of Sub IBs</h3>
                
                <!-- Pills -->
                <nav class="flex space-x-1 bg-[var(--bg-tertiary)] p-1 rounded-lg border border-[var(--border-secondary)]">
                    <a href="#" class="bg-[var(--bg-primary)] text-[var(--text-primary)] px-4 py-1.5 rounded-md text-xs font-semibold shadow-sm border border-[var(--border-secondary)]">All</a>
                    <a href="#" class="text-[var(--text-secondary)] hover:text-[var(--text-primary)] px-4 py-1.5 rounded-md text-xs font-medium transition-colors">Yearly</a>
                    <a href="#" class="text-[var(--text-secondary)] hover:text-[var(--text-primary)] px-4 py-1.5 rounded-md text-xs font-medium transition-colors">Monthly</a>
                    <a href="#" class="text-[var(--text-secondary)] hover:text-[var(--text-primary)] px-4 py-1.5 rounded-md text-xs font-medium transition-colors">Weekly</a>
                </nav>
            </div>

            <div class="overflow-x-auto bg-[var(--bg-primary)] flex-grow">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-[var(--border-secondary)] bg-[var(--bg-tertiary)]">
                            @foreach (var head in new[] { "ID", "Name", "Email", "Total Lots", "Commission Earned" })
                            {
                                <th class="py-3 px-5 text-xs text-left text-[var(--text-secondary)] font-semibold uppercase tracking-wider ">@head</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="5" class="py-8 text-center text-sm font-medium text-[var(--text-tertiary)]">No data available in table</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
