@{
    ViewData["Title"] = "IB Dashboard";
}

<div class="p-6 md:p-8">
    <div class="max-w-6xl space-y-6">
        <div>
            <h1 class="text-2xl font-bold text-[var(--text-primary)]">IB Dashboard</h1>
            <p class="text-[var(--text-secondary)]">Overview of your Introducing Broker performance</p>
        </div>
        <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-3xl p-8 text-center text-[var(--text-tertiary)]">
            <h3 class="text-2xl font-bold mb-4">Performance Metrics</h3>
            <p>Commission charts, referral stats, and volume metrics will be displayed here.</p>
        </div>
    </div>
</div>
