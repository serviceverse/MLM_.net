@{
    ViewData["Title"] = "Tree Charts";
}

<div class="p-4 md:p-8 space-y-6 ">
    <div class="mb-2">
        <h1 class="text-3xl font-bold text-[var(--text-primary)] tracking-tight">Tree Charts</h1>
        <p class="text-[var(--text-secondary)] mt-1">Visual representation of your IB network downline</p>
    </div>

    <!-- Chart Card -->
    <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-2xl p-8 shadow-sm min-h-[600px] flex items-center justify-center">
        <div class="text-center space-y-4">
            <div class="w-24 h-24 bg-indigo-50 rounded-full flex items-center justify-center mx-auto border border-indigo-100 shadow-inner">
                <svg class="w-12 h-12 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            </div>
            <h3 class="text-2xl font-bold text-[var(--text-primary)]">Interactive Tree Chart</h3>
            <p class="text-[var(--text-secondary)] max-w-md mx-auto font-medium">
                Once your sub-IBs and clients are registered, their hierarchy will appear here in an interactive tree diagram.
            </p>
        </div>
    </div>
</div>
