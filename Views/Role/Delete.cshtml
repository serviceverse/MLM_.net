@model MLM.Models.Role

@{
    ViewData["Title"] = "Delete Role";
}

<div class="p-6 md:p-8">
    <div class="max-w-6xl space-y-4">
        <div>
            <h1 class="text-4xl font-bold text-red-500 mb-2">Delete Role</h1>
            <p class="text-[var(--text-secondary)]">Are you sure you want to delete this role? This action cannot be undone.</p>
        </div>

        <div class="bg-[var(--bg-secondary)] border border-red-500/30 rounded-3xl p-8 shadow-lg shadow-red-500/5">
            <div class="space-y-4">
                <div class="grid grid-cols-3 border-b border-[var(--border-secondary)] pb-4">
                    <div class="text-[var(--text-tertiary)] font-medium">Role Name</div>
                    <div class="col-span-2 text-[var(--text-primary)] font-semibold">@Model.Name</div>
                </div>
                
                <div class="grid grid-cols-3 border-b border-[var(--border-secondary)] pb-4">
                    <div class="text-[var(--text-tertiary)] font-medium">Description</div>
                    <div class="col-span-2 text-[var(--text-primary)]">@Model.Description</div>
                </div>

                <div class="grid grid-cols-3 pb-4">
                    <div class="text-[var(--text-tertiary)] font-medium">Admin Access</div>
                    <div class="col-span-2">
                        @if(Model.IsAdmin)
                        {
                            <span class="bg-red-500/20 text-red-500 px-3 py-1 rounded-full text-sm font-medium">Yes, Admin</span>
                        }
                        else
                        {
                            <span class="bg-gray-500/20 text-gray-400 px-3 py-1 rounded-full text-sm font-medium">No</span>
                        }
                    </div>
                </div>

                <form asp-action="Delete" class="pt-6 flex items-center space-x-4">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="bg-red-500 hover:bg-red-600 text-white font-semibold px-6 py-2 rounded-sm text-sm transition-colors flex items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                        Confirm Delete
                    </button>
                    <a asp-action="Index" class="text-[var(--text-secondary)] hover:text-[var(--text-primary)] font-medium px-4 py-2 transition-colors">
                        Cancel
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>
