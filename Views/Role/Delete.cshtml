@model MLM.Models.Role

@{
    ViewData["Title"] = "Delete Role";
}

<div class="container mt-4">
    <div class="alert alert-danger" role="alert">
        <h4 class="alert-heading">Are you sure you want to delete this role?</h4>
        <p>Deleting this role is a permanent action and cannot be undone.</p>
    </div>

    <div class="card shadow-sm border-danger mt-3" style="max-width: 500px;">
        <div class="card-body">
            <h5 class="card-title text-danger">Role Details</h5>
            <dl class="row mt-3">
                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Name)</dt>
                <dd class="col-sm-8 fw-bold">@Html.DisplayFor(model => model.Name)</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-danger">Confirm Delete</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
