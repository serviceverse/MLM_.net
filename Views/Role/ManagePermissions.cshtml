@model MLM.Models.Role

@{
    ViewData["Title"] = "Manage Permissions";
    var modules = ViewBag.Modules as List<MLM.Models.AppModule>;
    var actions = ViewBag.Actions as List<MLM.Models.AppAction>;
    var existingPermissions = ViewBag.ExistingPermissions as List<MLM.Models.Permission>;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Manage Permissions for: <span class="text-primary">@Model.Name</span></h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Roles</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <form asp-action="UpdatePermissions" method="post">
                <input type="hidden" name="roleId" value="@Model.Id" />
                
                <div class="table-responsive">
                    <table class="table table-hover table-bordered mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Module</th>
                                @if(actions != null)
                                {
                                    @foreach(var act in actions)
                                    {
                                        <th class="text-center">@act.Name</th>
                                    }
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @if(modules != null && actions != null)
                            {
                                @foreach(var mod in modules)
                                {
                                    <tr>
                                        <td class="fw-bold align-middle">@mod.Name</td>
                                        @foreach(var act in actions)
                                        {
                                            var isChecked = existingPermissions?.Any(p => p.AppModuleId == mod.Id && p.AppActionId == act.Id) ?? false;
                                            <td class="text-center align-middle">
                                                <div class="form-check form-switch d-inline-block">
                                                    <input class="form-check-input" type="checkbox" 
                                                           name="permissions" value="@(mod.Id)_@(act.Id)" 
                                                           @(isChecked ? "checked" : "")>
                                                </div>
                                            </td>
                                        }
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <div class="p-4 bg-light border-top text-end">
                    <button type="submit" class="btn btn-primary px-4">Save Permissions</button>
                </div>
            </form>
        </div>
    </div>
</div>
