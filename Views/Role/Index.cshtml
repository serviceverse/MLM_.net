@model IEnumerable<MLM.Models.Role>

@{
    ViewData["Title"] = "Manage Roles";
}

<div class="p-6 md:p-8">
    
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-[var(--text-primary)]">Manage Roles</h1>
                <p class="text-[var(--text-secondary)]">Create and manage user roles in the system</p>
            </div>
            <a asp-action="Create" class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] font-semibold px-6 py-2 rounded-xl transition-colors flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Create New Role
            </a>
        </div>

        <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-3xl p-8 overflow-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-[var(--border-primary)] text-left">
                        <th class="py-4 px-4 text-[var(--text-secondary)] uppercase text-sm font-semibold">@Html.DisplayNameFor(model => model.Name)</th>
                        <th class="py-4 px-4 text-[var(--text-secondary)] uppercase text-sm font-semibold text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="border-b border-[var(--border-secondary)] hover:bg-[var(--bg-tertiary)]/50 transition-colors">
                            <td class="py-4 px-4 text-[var(--text-primary)] font-medium">
                                @Html.DisplayFor(modelItem => item.Name)
                            </td>
                            <td class="py-4 px-4 text-right">
                                <div class="flex items-center justify-end space-x-3">
                                    <a asp-controller="Settings" asp-action="MenuPermission" asp-route-roleId="@item.Id" class="text-blue-500 hover:text-blue-400 font-medium text-sm flex items-center">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                        Permissions
                                    </a>
                                    <span class="text-[var(--text-tertiary)]">|</span>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="text-[var(--button-primary-bg)] hover:text-[var(--button-primary-hover-bg)] font-medium text-sm">Edit</a>
                                    <span class="text-[var(--text-tertiary)]">|</span>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="text-red-500 hover:text-red-400 font-medium text-sm">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
