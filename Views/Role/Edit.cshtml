@model MLM.Models.Role

@{
    ViewData["Title"] = "Edit Role";
}

<div class="p-6 md:p-8">
    <div class="max-w-6xl space-y-6">
        <div>
            <h1 class="text-2xl font-bold text-[var(--text-primary)]">Edit Role</h1>
            <p class="text-[var(--text-secondary)]">Modify role details and admin access</p>
        </div>

        <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-xl shadow-sm p-6 md:p-8">
            <form asp-action="Edit" class="space-y-6">
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="space-y-2">
                    <label asp-for="Name" class="text-[var(--text-tertiary)] font-medium block">Role Name <span class="text-red-400">*</span></label>
                    <input asp-for="Name" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-3 px-4 outline-none" required />
                    <span asp-validation-for="Name" class="text-red-500 text-sm"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Description" class="text-[var(--text-tertiary)] font-medium block">Description</label>
                    <textarea asp-for="Description" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-3 px-4 outline-none min-h-[100px] resize-none"></textarea>
                    <span asp-validation-for="Description" class="text-red-500 text-sm"></span>
                </div>

                <div class="flex items-center space-x-2 pt-2">
                    <input asp-for="IsAdmin" type="checkbox" class="w-4 h-4 rounded border-[var(--border-secondary)] bg-[var(--bg-tertiary)] text-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)]" />
                    <label asp-for="IsAdmin" class="text-[var(--text-primary)] font-medium">Is Admin Role?</label>
                </div>

                <div class="col-span-full mt-4 flex items-center space-x-4 pt-6">
                    <button type="submit" class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] font-semibold px-8 py-3 rounded-xl transition-colors">
                        Save Changes
                    </button>
                    <a asp-action="Index" class="text-[var(--text-secondary)] hover:text-[var(--text-primary)] font-medium px-4 py-2 transition-colors">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
