@{
    ViewData["Title"] = "Create Iman Account";
}
<div class="p-6 md:p-8">
    <div class="max-w-6xl space-y-4">
        <div>
            <h1 class="text-2xl font-bold text-[var(--text-primary)]">Create Iman Account</h1>
            <p class="text-[var(--text-secondary)]">Set up your new Iman trading account</p>
        </div>
        <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-xl shadow-sm p-6 md:p-8">
            <form class="grid grid-cols-1 lg:grid-cols-2 gap-4 relative">
                <div class="space-y-2">
                    <label class="text-[var(--text-primary)] text-sm font-medium mb-1">Select Account Type <span class="text-red-400">*</span></label>
                    <select class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-2 px-3 text-sm outline-none focus:ring-2 focus:ring-[var(--button-primary-bg)]">
                        <option value="">Please choose an account type...</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="text-[var(--text-primary)] text-sm font-medium mb-1">Select Leverage <span class="text-red-400">*</span></label>
                    <select class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-2 px-3 text-sm outline-none focus:ring-2 focus:ring-[var(--button-primary-bg)]">
                        <option value="">Please choose leverage...</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="text-[var(--text-primary)] text-sm font-medium mb-1">Password <span class="text-red-400">*</span></label>
                    <input type="password" placeholder="Enter Password" class="w-full rounded-xl px-3 py-3 text-sm bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--button-primary-bg)] border border-[var(--border-secondary)]" />
                </div>
                <div class="col-span-full mt-4 flex gap-4 pt-4">
                    <button type="submit" class="bg-[var(--button-primary-bg)] text-[var(--button-primary-text)] px-6 py-2 rounded-sm text-sm font-semibold hover:opacity-90 ">Create Account</button>
                    <button type="reset" class="border border-[var(--border-secondary)] text-[var(--text-secondary)] bg-transparent hover:bg-[var(--bg-tertiary)] px-4 py-2 rounded-sm text-sm font-semibold">Reset</button>
                </div>
            </form>
        </div>
        <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-2xl p-6 opacity-80">
            <h3 class="text-lg font-semibold text-[var(--text-primary)] mb-3">Account Information</h3>
            <ul class="space-y-2 text-[var(--text-secondary)] text-sm">
                <li>Ã¢â‚¬Â¢ <strong>Password:</strong> Used for full trading access and account management</li>
                <li>Ã¢â‚¬Â¢ Passwords must be at least 8 characters long</li>
                <li>Ã¢â‚¬Â¢ Account creation typically takes 1-2 minutes to process</li>
                <li>Ã¢â‚¬Â¢ You will receive account details via email once created successfully</li>
            </ul>
        </div>
        <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-2xl p-6 opacity-80">
            <h3 class="text-lg font-semibold text-[var(--text-primary)] mb-3">Account Types</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                <div class="space-y-2">
                    <div class="text-[var(--text-secondary)]"><strong class="text-[var(--text-primary)]">Standard:</strong> Basic trading account</div>
                    <div class="text-[var(--text-secondary)]"><strong class="text-[var(--text-primary)]">Bay:</strong> Premium trading features</div>
                    <div class="text-[var(--text-secondary)]"><strong class="text-[var(--text-primary)]">Silver:</strong> Enhanced trading account</div>
                </div>
                <div class="space-y-2">
                    <div class="text-[var(--text-secondary)]"><strong class="text-[var(--text-primary)]">Gold:</strong> Premium account with ECN access</div>
                    <div class="text-[var(--text-secondary)]"><strong class="text-[var(--text-primary)]">Leverage:</strong> Choose up to your accounts maximum</div>
                </div>
            </div>
        </div>
    </div>
</div>
