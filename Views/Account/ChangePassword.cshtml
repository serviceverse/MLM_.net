@{
    ViewData["Title"] = "Change Crib Password";
}
<div class="p-6 md:p-8">
    <div class="max-w-6xl space-y-6">
        <!-- Header -->
        <div>
            <h1 class="text-2xl font-bold text-[var(--text-primary)]">Change Crib Password</h1>
            <p class="text-[var(--text-secondary)]">Update your Crib account passwords</p>
        </div>
        <!-- Form -->
        <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-xl shadow-sm p-6 md:p-8">
            <form class="grid grid-cols-1 lg:grid-cols-2 gap-6 relative">
                <div class="space-y-2">
                    <label class="text-[var(--text-primary)] font-medium">Select Crib ID <span class="text-red-400">*</span></label>
                    <select class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-3 px-3 outline-none">
                        <option value="">Please Choose...</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="text-[var(--text-primary)] font-medium">Password <span class="text-red-400">*</span></label>
                    <input type="password" placeholder="Enter Password" class="flex w-full rounded-xl border px-3 py-3 text-sm bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--button-primary-bg)]" />
                </div>
                <div class="col-span-full mt-4 flex justify-start pt-4">
                    <button type="submit" class="bg-[var(--button-primary-bg)] text-[var(--button-primary-text)] hover:opacity-90 px-8 py-3 rounded-xl font-semibold">
                        Submit
                    </button>
                </div>
            </form>
        </div>
        <!-- Info -->
        <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-2xl p-6 opacity-80">
            <h3 class="text-lg font-semibold text-[var(--text-primary)] mb-3">Password Change Information</h3>
            <ul class="space-y-2 text-[var(--text-secondary)] text-sm">
                <li>• Password changes take effect immediately</li>
                <li>• You will need to re-login to Crib with new passwords</li>
                <li>• Keep your passwords secure and don't share them</li>
                <li>• Contact support if you experience any issues</li>
            </ul>
        </div>
    </div>
</div>
