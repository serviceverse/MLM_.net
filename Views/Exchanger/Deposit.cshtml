@{
    ViewData["Title"] = "Exchanger Deposit Report";
}

<div class="p-2 md:p-4">
    <!-- Header -->
    <div class="mb-4 flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-[var(--text-primary)]">Exchanger Deposit Report</h1>
            <p class="text-sm text-[var(--text-secondary)] mt-1">Track and analyze all deposits made by exchangers</p>
        </div>
    </div>

    <!-- Filters -->
    <div class="bg-white border border-[var(--border-secondary)] rounded-sm shadow-none p-4 mb-4">
        <div class="flex flex-wrap items-end gap-4">
            <div class="space-y-1.5">
                <label class="text-xs font-semibold text-[var(--text-primary)]">From</label>
                <input type="date" class="bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-1.5 px-3 text-xs outline-none focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)]" />
            </div>
            <div class="space-y-1.5">
                <label class="text-xs font-semibold text-[var(--text-primary)]">To</label>
                <input type="date" class="bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-1.5 px-3 text-xs outline-none focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)]" />
            </div>
            <div class="space-y-1.5">
                <label class="text-xs font-semibold text-[var(--text-primary)]">Status</label>
                <select class="w-32 bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-1.5 px-3 text-xs outline-none focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)]">
                    <option>All</option>
                </select>
            </div>
            <div class="space-y-1.5">
                <label class="text-xs font-semibold text-[var(--text-primary)]">Method</label>
                <select class="w-32 bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-1.5 px-3 text-xs outline-none focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)]">
                    <option>All</option>
                </select>
            </div>
            <div class="space-y-1.5">
                <label class="text-xs font-semibold text-[var(--text-primary)]">Exchanger</label>
                <select class="w-40 bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-1.5 px-3 text-xs outline-none focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)]">
                    <option>All</option>
                </select>
            </div>
            <button class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] px-4 py-1.5 rounded-sm text-xs font-semibold transition-colors">
                Search
            </button>
        </div>
    </div>

    <!-- Data/Table Section -->
    <div class="bg-white border border-[var(--border-secondary)] rounded-sm shadow-none">
        <div class="px-2 py-2 border-b border-[var(--border-secondary)] flex flex-wrap justify-between items-center gap-4">
            <!-- Entries per page and Export -->
            <div class="flex items-center space-x-4">
                <div class="flex items-center space-x-2">
                    <span class="text-[var(--text-secondary)] text-xs">Show</span>
                    <select class="bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-1 px-2 text-xs outline-none">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                    </select>
                    <span class="text-[var(--text-secondary)] text-xs">entries</span>
                </div>
                <button class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] px-3 py-1 rounded-sm text-xs font-semibold flex items-center transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 mr-1.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Export CSV
                </button>
            </div>

            <!-- Search bar -->
            <div class="flex items-center space-x-2">
                <div class="relative">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-[var(--text-tertiary)] absolute left-2.5 top-1/2 -translate-y-1/2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <input type="text" placeholder="Search deposits..." class="pl-8 bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)] rounded-sm py-1.5 text-xs outline-none w-64" />
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-[var(--border-secondary)] text-left bg-[var(--bg-tertiary)]">
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-secondary)] font-semibold uppercase">ID</th>
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-secondary)] font-semibold uppercase">Name / Email</th>
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-secondary)] font-semibold uppercase">Iman ID</th>
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-secondary)] font-semibold uppercase">Amount</th>
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-secondary)] font-semibold uppercase">Payment Method</th>
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-secondary)] font-semibold uppercase">Note</th>
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-secondary)] font-semibold uppercase">Comment</th>
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-secondary)] font-semibold uppercase">Deposit Proof</th>
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-secondary)] font-semibold uppercase">Status</th>
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-secondary)] font-semibold uppercase">Date</th>
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-secondary)] font-semibold uppercase">Exchanger</th>
                        <th class="py-1.5 px-2 text-[11px] border-r border-[var(--border-secondary)] whitespace-nowrap text-[var(--text-secondary)] font-semibold uppercase">Approved / Rejected By</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="12" class="py-6 text-center text-xs text-[var(--text-secondary)]">
                            No deposits found
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination & info -->
        <div class="flex items-center justify-between p-2 border-t border-[var(--border-secondary)]">
            <div class="text-[var(--text-secondary)] text-xs">
                Showing 0 to 0 of 0 entries
            </div>
            <div class="flex items-center space-x-1">
                <button class="border border-[var(--border-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] bg-transparent rounded-sm px-2 py-1 text-xs inline-flex items-center opacity-50 cursor-not-allowed">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                    Prev
                </button>
                <button class="border border-[var(--border-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] bg-transparent rounded-sm px-2 py-1 text-xs inline-flex items-center opacity-50 cursor-not-allowed">
                    Next
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 ml-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </button>
            </div>
        </div>
    </div>
</div>
