@{
    ViewData["Title"] = "Exchanger Transfer";
}
<div class="p-6 md:p-8">
    <div class="page-scroll-content px-8 py-6 flex items-start justify-center">
        <div class="w-full bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-3xl shadow-md p-6 md:p-8 space-y-6">
            <h2 class="text-xl font-semibold text-[var(--text-primary)]">Exchanger Transfer</h2>
            <form class="grid grid-cols-1 lg:grid-cols-2 gap-6 relative">
                <div class="space-y-2">
                    <label class="text-sm font-medium text-[var(--text-primary)]">
                        From Exchanger ID <span class="text-red-500">*</span>
                    </label>
                    <input type="text" placeholder="Enter From Exchanger ID" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-2 px-3 outline-none" />
                </div>

                <div class="space-y-2">
                    <label class="text-sm font-medium text-[var(--text-primary)]">
                        To Exchanger ID <span class="text-red-500">*</span>
                    </label>
                    <input type="text" placeholder="Enter To Exchanger ID" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-2 px-3 outline-none" />
                </div>

                <div class="space-y-2">
                    <label class="text-sm font-medium text-[var(--text-primary)]">
                        Amount <span class="text-red-500">*</span>
                    </label>
                    <input type="text" placeholder="Enter transfer amount" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-2 px-3 outline-none" />
                </div>

                <div class="space-y-2">
                    <label class="text-sm font-medium text-[var(--text-primary)]">Note</label>
                    <input type="text" placeholder="Optional note" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-2 px-3 outline-none" />
                </div>

                <button type="button" class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] hover:text-[var(--button-primary-hover-text)] w-full py-2 rounded-xl font-semibold">
                    Submit Transfer
                </button>
            </form>
        </div>
    </div>
</div>
