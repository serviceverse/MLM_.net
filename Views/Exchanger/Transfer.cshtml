@{
    ViewData["Title"] = "Exchanger Transfer";
}

<div class="p-2 md:p-4">
    <div class="mb-4 flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-[var(--text-primary)]">Exchanger Transfer</h1>
            <p class="text-sm text-[var(--text-secondary)] mt-1">Transfer funds between exchangers</p>
        </div>
    </div>

    <div class="bg-white border border-[var(--border-secondary)] rounded-sm shadow-none p-4 md:p-6 max-w-2xl">
        <form class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="space-y-1.5">
                    <label class="text-xs font-semibold text-[var(--text-primary)]">
                        From Exchanger ID <span class="text-red-500">*</span>
                    </label>
                    <input type="text" placeholder="Enter From Exchanger ID" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] rounded-sm py-1.5 px-3 text-xs focus:outline-none focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)]" />
                </div>

                <div class="space-y-1.5">
                    <label class="text-xs font-semibold text-[var(--text-primary)]">
                        To Exchanger ID <span class="text-red-500">*</span>
                    </label>
                    <input type="text" placeholder="Enter To Exchanger ID" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] rounded-sm py-1.5 px-3 text-xs focus:outline-none focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)]" />
                </div>

                <div class="space-y-1.5">
                    <label class="text-xs font-semibold text-[var(--text-primary)]">
                        Amount <span class="text-red-500">*</span>
                    </label>
                    <input type="number" placeholder="Enter transfer amount" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] rounded-sm py-1.5 px-3 text-xs focus:outline-none focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)]" />
                </div>

                <div class="space-y-1.5">
                    <label class="text-xs font-semibold text-[var(--text-primary)]">Note</label>
                    <input type="text" placeholder="Optional note" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] rounded-sm py-1.5 px-3 text-xs focus:outline-none focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)]" />
                </div>
            </div>

            <button type="button" class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] px-4 py-2 rounded-sm text-xs font-semibold mt-4">
                Submit Transfer
            </button>
        </form>
    </div>
</div>
