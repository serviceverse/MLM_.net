@{
    ViewData["Title"] = "Send Email";
}
<div class="custome-scroll min-h-screen bg-primary text-[var(--text-primary)] p-8">
    <div class="w-full space-y-8">
        <h1 class="text-4xl font-bold mb-4">Send Email</h1>
        <p class="text-[var(--text-secondary)]">
            Select recipients, add a subject and message, then click send.
        </p>

        <div class="bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-3xl p-8 space-y-6">
            <!-- Select All Toggle -->
            <div class="flex items-center gap-3">
                <input type="checkbox" id="selectAll" class="w-4 h-4 rounded border-[var(--border-secondary)] bg-[var(--bg-tertiary)]" />
                <label for="selectAll" class="text-[var(--text-primary)]">Send to all clients</label>
            </div>

            <!-- Email Selection -->
            <div class="space-y-2 relative" id="emailSelectionDiv">
                <label class="text-[var(--text-primary)] block">Search & Add Emails</label>
                <input type="search" placeholder="Search by name or email" class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] rounded-xl py-3 px-4 outline-none focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)]" />
            </div>

            <!-- Subject -->
            <div class="space-y-2">
                <label class="text-[var(--text-primary)] block">Subject</label>
                <input type="text" placeholder="Enter subject" class="w-full bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] rounded-xl py-3 px-4 outline-none focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)]" />
            </div>

            <!-- Rich Text Toggle -->
            <div class="flex items-center gap-2">
                <input type="checkbox" id="useRichText" checked class="w-4 h-4 rounded border-[var(--border-secondary)] bg-[var(--bg-tertiary)]" />
                <label for="useRichText" class="text-[var(--text-primary)]">Use rich text editor</label>
            </div>

            <!-- Body -->
            <div class="space-y-2">
                <label class="text-[var(--text-primary)] block">Message</label>

                <!-- Toolbar -->
                <div class="col-span-full mt-4 flex flex-wrap items-center gap-2 p-2 rounded-lg border border-[var(--border-secondary)] bg-[var(--bg-tertiary)]">
                    <button type="button" class="h-8 px-2 text-[var(--text-primary)] hover:bg-[var(--bg-secondary)] rounded" title="Bold">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 12a4 4 0 0 0 0-8H6v8"/><path d="M15 20a4 4 0 0 0 0-8H6v8Z"/></svg>
                    </button>
                    <button type="button" class="h-8 px-2 text-[var(--text-primary)] hover:bg-[var(--bg-secondary)] rounded italic" title="Italic">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/><line x1="15" y1="4" x2="9" y2="20"/></svg>
                    </button>
                    <button type="button" class="h-8 px-2 text-[var(--text-primary)] hover:bg-[var(--bg-secondary)] rounded underline" title="Underline">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3v7a6 6 0 0 0 6 6 6 6 0 0 0 6-6V3"/><line x1="4" y1="21" x2="20" y2="21"/></svg>
                    </button>
                    
                    <span class="mx-1 h-6 w-px bg-[var(--border-secondary)]"></span>
                    
                    <button type="button" class="h-8 px-2 text-[var(--text-primary)] hover:bg-[var(--bg-secondary)] rounded" title="Align Left">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="21" y1="6" x2="3" y2="6"/><line x1="15" y1="12" x2="3" y2="12"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
                    </button>
                    <button type="button" class="h-8 px-2 text-[var(--text-primary)] hover:bg-[var(--bg-secondary)] rounded" title="Align Center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="21" y1="6" x2="3" y2="6"/><line x1="17" y1="12" x2="7" y2="12"/><line x1="19" y1="18" x2="5" y2="18"/></svg>
                    </button>
                    <button type="button" class="h-8 px-2 text-[var(--text-primary)] hover:bg-[var(--bg-secondary)] rounded" title="Align Right">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="12" x2="9" y2="12"/><line x1="21" y1="18" x2="7" y2="18"/></svg>
                    </button>
                    
                    <span class="mx-1 h-6 w-px bg-[var(--border-secondary)]"></span>
                    
                    <button type="button" class="h-8 px-2 text-[var(--text-primary)] hover:bg-[var(--bg-secondary)] rounded" title="Unordered List">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                    </button>
                    <button type="button" class="h-8 px-2 text-[var(--text-primary)] hover:bg-[var(--bg-secondary)] rounded" title="Ordered List">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="10" y1="6" x2="21" y2="6"/><line x1="10" y1="12" x2="21" y2="12"/><line x1="10" y1="18" x2="21" y2="18"/><path d="M4 6h1v4"/><path d="M4 10h2"/><path d="M6 18H4c0-1 2-2 2-3s-1-1.5-2-1"/></svg>
                    </button>
                    
                    <span class="mx-1 h-6 w-px bg-[var(--border-secondary)]"></span>
                    
                    <select class="bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-md px-2 py-1 text-sm outline-none">
                        <option value="inherit">Default Font</option>
                        <option value="Inter, system-ui, sans-serif">Inter</option>
                        <option value="Georgia, serif">Georgia</option>
                    </select>

                    <select class="bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-md px-2 py-1 text-sm outline-none">
                        <option value="3">Normal Size</option>
                        <option value="4">Large</option>
                        <option value="5">Huge</option>
                    </select>

                    <span class="mx-1 h-6 w-px bg-[var(--border-secondary)]"></span>

                    <button type="button" class="h-8 px-2 text-[var(--text-primary)] hover:bg-[var(--bg-secondary)] rounded" title="Insert Image">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    </button>
                </div>

                <!-- Editable area -->
                <div contenteditable="true" class="min-h-[220px] rounded-xl p-4 bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] focus:outline-none text-[var(--text-primary)]">
                    Type your message here...
                </div>
            </div>

            <!-- Attachments -->
            <div class="space-y-2">
                <label class="text-[var(--text-primary)] block">Attachments</label>
                <div class="flex flex-col gap-2">
                    <div class="flex items-center gap-3">
                        <input type="file" multiple accept=".pdf,.doc,.docx,.txt,.png,.jpg,.jpeg,.gif,.webp" class="bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] file:mr-4 file:rounded-md file:border-0 file:px-3 file:py-2 file:bg-[var(--button-secondary-bg)] file:text-[var(--button-secondary-text)] hover:file:bg-[var(--button-secondary-hover-bg)]" />
                        <div class="text-[var(--text-tertiary)] text-sm flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                            Supported: images, PDF, DOC/DOCX, TXT
                        </div>
                    </div>
                </div>
            </div>

            <!-- Send Button -->
            <button class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] hover:text-[var(--button-primary-hover-text)] px-8 py-3 rounded-xl font-semibold flex items-center justify-center gap-2 mt-4">
                Send Email
            </button>
        </div>
    </div>
