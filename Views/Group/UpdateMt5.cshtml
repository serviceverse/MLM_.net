@{
    ViewData["Title"] = "Update Group";
}
<div class="p-6 md:p-8">
        <div class="w-full">
            <div class="w-full bg-[var(--bg-secondary)] border border-[var(--border-primary)] rounded-3xl shadow-md p-6 md:p-8 space-y-6">
                <h2 class="text-xl font-semibold text-[var(--text-primary)]">Update Group</h2>

                <!-- Search group by name -->
                <div class="space-y-2">
                    <label class="text-sm font-medium text-[var(--text-primary)]">
                        Search Group by Name
                    </label>
                    <input type="text" placeholder="Start typing group name..." class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] rounded-lg py-2 px-3 outline-none focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)]" />
                </div>

                <form class="grid grid-cols-1 lg:grid-cols-2 gap-6 relative">
                    <div class="space-y-2">
                        <label class="text-sm font-medium text-[var(--text-primary)]">
                            Group Name <span class="text-red-400">*</span>
                        </label>
                        <input type="text" placeholder="Enter group name" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] rounded-lg py-2 px-3 outline-none focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)]" />
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-medium text-[var(--text-primary)]">
                            Group Code <span class="text-red-400">*</span>
                        </label>
                        <input type="text" placeholder="Unique Crib group code" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] rounded-lg py-2 px-3 outline-none focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)]" />
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-medium text-[var(--text-primary)]">
                            Leverage <span class="text-red-400">*</span>
                        </label>
                        <input type="text" placeholder="e.g., 1:100" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] rounded-lg py-2 px-3 outline-none focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)]" />
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-medium text-[var(--text-primary)]">
                            Commission <span class="text-red-400">*</span>
                        </label>
                        <input type="text" placeholder="Commission per lot" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] rounded-lg py-2 px-3 outline-none focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)]" />
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-medium text-[var(--text-primary)]">
                            Description
                        </label>
                        <input type="text" placeholder="Optional description" class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] rounded-lg py-2 px-3 outline-none focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)]" />
                    </div>

                    <button type="button" class="w-full py-2 rounded-xl font-semibold bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] hover:text-[var(--button-primary-hover-text)]">
                        Update Group
                    </button>
                </form>
            </div>
        </div>
    </div>
