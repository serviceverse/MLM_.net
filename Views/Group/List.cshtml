@{
    ViewData["Title"] = "Groups List";
}
<div class="p-6 md:p-8">
    
        <!-- Page Header -->
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-[var(--text-primary)]">Groups</h1>
        <p class="text-sm text-[var(--text-secondary)] mt-1">List of all configured trading groups</p>
    </div>

    <!-- Main Card -->
    <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-xl shadow-sm">
            <!-- Search Row -->
        <div class="px-6 py-4 border-b border-[var(--border-secondary)] flex flex-wrap justify-between items-center gap-4">
                <div class="text-[var(--text-secondary)]">Search:</div>
                <div class="relative w-80">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--text-tertiary)] absolute left-3 top-1/2 -translate-y-1/2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <input type="text" placeholder="Search by name, code or manager group..." class="pl-10 bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)] rounded-xl py-2 px-3 w-full outline-none" />
                </div>
            </div>

            <!-- Table -->
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-[var(--bg-tertiary)]">
                        <tr>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Name</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Code</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Manager Group</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Minimum Deposit</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Commission</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Spread</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Maximum Leverage</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Status</th>
                            <th class="text-left py-4 px-4 text-[var(--text-secondary)] uppercase font-semibold">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="9" class="py-8 text-center text-[var(--text-secondary)]">
                                No groups found
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
