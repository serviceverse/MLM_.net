<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta FullName="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TheCubeFactory</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MLM.styles.css" asp-append-version="true" />
    <script src="~/lib/tailwind/tailwindcss.js"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --sidebar-width: 260px;
            --topbar-height: 70px;
            --primary-color: var(--button-primary-bg);
            --primary-hover: var(--button-primary-hover-bg);
            --sidebar-bg: var(--bg-primary);
            --sidebar-text: var(--text-secondary);
            --sidebar-hover-bg: var(--bg-secondary);
            --sidebar-hover-text: var(--text-primary);
            --body-bg: var(--bg-secondary);
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background-color: var(--body-bg);
            overflow-x: hidden;
            margin: 0;
            padding: 0;
        }

        /* Layout Structure */
        .app-wrapper {
            display: flex;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
        }

        /* Sidebar */
        .sidebar {
            width: var(--sidebar-width);
            background-color: var(--sidebar-bg);
            color: var(--sidebar-text);
            display: flex;
            flex-direction: column;
            transition: transform 0.3s ease;
            z-index: 1040;
            flex-shrink: 0;
        }

        .sidebar-header {
            height: var(--topbar-height);
            display: flex;
            align-items: center;
            padding: 0 24px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            background: rgba(0,0,0,0.2);
        }

        .sidebar-brand {
            color: var(--text-primary);
            font-size: 20px;
            font-weight: 700;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .sidebar-brand:hover {
            color: var(--text-primary);
        }

        .brand-icon {
            width: 32px;
            height: 32px;
            background: linear-gradient(135deg, var(--primary-color), #818cf8);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 16px;
        }

        .sidebar-menu {
            padding: 20px 12px;
            flex-grow: 1;
            overflow-y: auto;
        }
        
        /* Custom Scrollbar for Sidebar */
        .sidebar-menu::-webkit-scrollbar {
            width: 4px;
        }
        .sidebar-menu::-webkit-scrollbar-track {
            background: transparent;
        }
        .sidebar-menu::-webkit-scrollbar-thumb {
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
        }
        .sidebar-menu:hover::-webkit-scrollbar-thumb {
            background-color: rgba(255, 255, 255, 0.2);
        }

        .menu-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #64748b;
            font-weight: 600;
            margin: 16px 12px 8px;
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: 10px 16px;
            color: var(--sidebar-text);
            text-decoration: none;
            border-radius: 8px;
            margin-bottom: 4px;
            font-weight: 500;
            font-size: 14px;
            transition: all 0.2s ease;
            gap: 12px;
        }

        .menu-item i {
            font-size: 18px;
            transition: color 0.2s ease;
        }

        .menu-item:hover {
            background-color: var(--sidebar-hover-bg);
            color: var(--sidebar-hover-text);
        }

        .menu-item:hover i {
            color: var(--primary-color);
        }

        .menu-item.active {
            background-color: rgba(79, 70, 229, 0.1);
            color: var(--primary-color);
        }

        .menu-item.active i {
            color: var(--primary-color);
        }

        /* Custom Accordion overrides for sidebar */
        .sidebar .accordion-button {
            color: var(--sidebar-text) !important;
            border-radius: 8px;
            transition: all 0.2s ease;
        }
        .sidebar .accordion-button:not(.collapsed) {
            color: var(--sidebar-hover-text) !important;
            background-color: var(--sidebar-hover-bg) !important;
        }
        .sidebar .accordion-button:hover {
            color: var(--sidebar-hover-text) !important;
            background-color: var(--sidebar-hover-bg) !important;
        }
        .sidebar .accordion-button:focus {
            box-shadow: none;
        }
        .sidebar .accordion-button::after {
            filter: invert(0.6); /* make chevron light */
            background-size: 0.9rem;
        }
        .sidebar .accordion-button:not(.collapsed)::after {
            filter: invert(1);
        }
        
        /* Adjusted menu item for nesting */
        .sidebar .menu-item {
            padding: 8px 16px 8px 46px;
            font-size: 13.5px;
            color: #64748b;
        }
        .sidebar .menu-item i {
            font-size: 16px;
            opacity: 0.5;
        }
        .sidebar .menu-item:hover {
            color: var(--sidebar-hover-text);
            background-color: transparent;
        }
        .sidebar .menu-item:hover i {
            opacity: 1;
            color: var(--sidebar-hover-text);
        }
        .sidebar .menu-item.active {
            color: var(--primary-color);
            background-color: transparent;
            font-weight: 600;
        }
        .sidebar .menu-item.active i {
            color: var(--primary-color);
            opacity: 1;
        }

        /* Main Content Area */
        .main-wrapper {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            min-width: 0; /* Important for flex overflow */
        }

        /* Topbar */
        .topbar {
            height: var(--topbar-height);
            background-color: white;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            flex-shrink: 0;
            z-index: 1030;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .toggle-btn {
            background: transparent;
            border: none;
            font-size: 24px;
            color: #475569;
            cursor: pointer;
            padding: 0;
            display: none; /* Hidden on desktop */
        }

        .toggle-btn:hover {
            color: var(--primary-color);
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        /* Profile Dropdown */
        .profile-dropdown .dropdown-toggle {
            display: flex;
            align-items: center;
            gap: 12px;
            background: transparent;
            border: none;
            padding: 4px 8px;
            border-radius: 8px;
            cursor: pointer;
            text-decoration: none;
            color: #334155;
            font-weight: 500;
        }

        .profile-dropdown .dropdown-toggle:hover {
            background: #f1f5f9;
        }

        .profile-dropdown .dropdown-toggle::after {
            display: none;
        }

        .avatar {
            width: 36px;
            height: 36px;
            background-color: var(--primary-color);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 14px;
        }

        .dropdown-menu-custom {
            border: 1px solid #e2e8f0;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            border-radius: 12px;
            padding: 8px 0;
            margin-top: 10px;
            min-width: 200px;
        }

        .dropdown-menu-custom .dropdown-item {
            padding: 8px 20px;
            font-size: 14px;
            color: #475569;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .dropdown-menu-custom .dropdown-item:hover {
            background-color: #f8fafc;
            color: var(--primary-color);
        }

        /* Content Body */
        .content-body {
            padding: 0;
            overflow-y: auto;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        /* Responsive Mobile */
        
    </style>
</head>
<body>

    <div class="app-wrapper">
        <!-- Mobile Overlay -->
        <div class="app-overlay" id="appOverlay"></div>

        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <a href="/" class="sidebar-brand">
                    <div class="brand-icon">
                        <i class="bi bi-box-fill"></i>
                    </div>
                    TheCubeFactory
                </a>
            </div>
            <div class="sidebar-menu">
                @await Component.InvokeAsync("Sidebar")
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-wrapper">
            <!-- Topbar -->
            <header class="topbar">
                <div class="topbar-left">
                    <button class="toggle-btn" id="sidebarToggle">
                        <i class="bi bi-list"></i>
                    </button>
                    <!-- Optional: Breadcrumbs or Page Title here -->
                    <h5 class="mb-0 text-dark fw-bold d-none d-md-block">@ViewData["Title"]</h5>
                </div>
                <div class="topbar-right">
                    <div class="col-span-full mt-4 dropdown profile-dropdown">
                        <button class="dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="avatar">
                                AD
                            </div>
                            <div class="d-none d-sm-block text-start">
                                <div class="fw-bold" style="font-size:14px; line-height:1.2;">Admin User</div>
                                <div class="text-muted" style="font-size:12px;">Administrator</div>
                            </div>
                            <i class="bi bi-chevron-down ms-2 text-muted" style="font-size: 12px;"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end dropdown-menu-custom">
                            <li><h6 class="dropdown-header">Welcome!</h6></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-person"></i> My Profile</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-gear"></i> Settings</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Login"><i class="bi bi-box-arrow-right"></i> Sign out</a></li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- Page Content -->
            <div class="content-body">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Sidebar Toggle Script -->
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var sidebarToggle = document.getElementById('sidebarToggle');
            var sidebar = document.getElementById('sidebar');
            var appOverlay = document.getElementById('appOverlay');

            function toggleSidebar() {
                sidebar.classList.toggle('show');
                appOverlay.classList.toggle('show');
            }

            if(sidebarToggle) {
                sidebarToggle.addEventListener('click', toggleSidebar);
            }
            if(appOverlay) {
                appOverlay.addEventListener('click', toggleSidebar);
            }
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
