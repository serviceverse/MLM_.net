@{
    ViewData["Title"] = "IB Requests";
}

<div class="p-4 md:p-8 space-y-6">
    <!-- Page Header -->
    <div class="mb-2 flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-[var(--text-primary)]">IB Requests</h1>
            <p class="text-sm text-[var(--text-secondary)] mt-1">View pending, approved, or rejected IB applications</p>
        </div>
    </div>

    <!-- Card Wrapper -->
    <div class="bg-[var(--bg-primary)] border border-[var(--border-secondary)] rounded-2xl shadow-sm overflow-hidden flex flex-col">
        
        <!-- Tabs (Using Alpine or simple CSS/JS for tab switching - keeping it static UI for now) -->
        <div class="p-5 border-b border-[var(--border-secondary)]">
            <nav class="flex space-x-2" aria-label="Tabs">
                <a href="#" class="bg-yellow-100 text-yellow-800 px-3 py-1.5 rounded-sm text-xs font-medium border border-yellow-200">
                    Pending
                </a>
                <a href="#" class="text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] px-3 py-1.5 rounded-sm text-xs font-medium">
                    Approved
                </a>
                <a href="#" class="text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] px-3 py-1.5 rounded-sm text-xs font-medium">
                    Rejected
                </a>
            </nav>
        </div>

        <!-- Filters -->
        <div class="p-5 border-b border-[var(--border-secondary)] flex flex-wrap items-center justify-between gap-4">
            <div class="flex items-center space-x-2">
                <span class="text-[var(--text-secondary)] text-sm">Show</span>
                <select class="h-9 w-20 rounded-lg border border-[var(--border-secondary)] bg-[var(--bg-primary)] text-[var(--text-primary)] px-2 py-1 text-sm shadow-sm focus:outline-none focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)]/20 transition-all">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
                <span class="text-[var(--text-secondary)] text-sm">entries</span>
            </div>

            <div class="flex items-center space-x-2">
                <span class="text-[var(--text-secondary)] text-sm">Search:</span>
                <div class="relative">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 text-gray-400 absolute left-2 top-1/2 transform -translate-y-1/2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <input type="text" placeholder="Search by name, email, contact..." class="flex h-8 w-64 rounded-sm border px-2 py-1 text-xs ring-offset-background pl-7 bg-[var(--bg-tertiary)] border-[var(--border-secondary)] text-[var(--text-primary)] placeholder-[var(--text-tertiary)] focus:border-[var(--button-primary-bg)] focus:ring-[var(--button-primary-bg)]" />
                </div>
            </div>
        </div>

        <!-- Table Content -->
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-[var(--border-secondary)] hover:bg-[var(--bg-tertiary)] hover:bg-[var(--bg-tertiary)]/50 transition-colors">
                        @foreach (var heading in new[] { "#", "Full Name", "Email", "Contact", "Country", "Status", "Actions" })
                        {
                            <th class="py-3 px-5 text-xs text-left text-[var(--text-secondary)] font-bold uppercase tracking-wider">
                                @heading
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.Pending == null || ((IEnumerable<dynamic>)ViewBag.Pending).Count() == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center py-8 text-[var(--text-tertiary)] font-medium text-sm">
                                No data available
                            </td>
                        </tr>
                    }
                    else
                    {
                        int index = 1;
                        foreach (var req in ViewBag.Pending)
                        {
                            <tr class="border-b border-[var(--border-secondary)] hover:bg-[var(--bg-tertiary)] hover:bg-[var(--bg-tertiary)]/50 transition-colors">
                                <td class="py-4 px-5 text-sm text-[var(--text-primary)] font-medium">@index</td>
                                <td class="py-4 px-5 text-sm text-[var(--text-primary)] font-medium">@req.FullName</td>
                                <td class="py-4 px-5 text-sm text-[var(--text-primary)] font-medium">@req.Email</td>
                                <td class="py-4 px-5 text-sm text-[var(--text-primary)] font-medium">@req.Contact</td>
                                <td class="py-4 px-5 text-sm text-[var(--text-primary)] font-medium">@req.Country</td>
                                <td class="py-1 px-2 text-[12px] whitespace-nowrap">
                                    <span class="inline-flex items-center rounded-sm border px-2.5 py-0.5 text-[10px] font-semibold bg-yellow-500/20 text-yellow-600 border-yellow-500/30">
                                        Pending
                                    </span>
                                </td>
                                <td class="py-1 px-2 text-[12px] whitespace-nowrap">
                                    <div class="flex gap-2">
                                        <button class="bg-green-600 hover:bg-green-700 text-white text-[10px] px-2 py-1 rounded-sm">Accept</button>
                                        <button class="bg-red-600 hover:bg-red-700 text-white text-[10px] px-2 py-1 rounded-sm">Reject</button>
                                    </div>
                                </td>
                            </tr>
                            index++;
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="p-5 border-t border-[var(--border-secondary)] flex flex-wrap items-center justify-between gap-4">
            <div class="text-[var(--text-secondary)] text-xs">
                Showing 0 to 0 of 0 entries
            </div>
            <div class="flex items-center space-x-2">
                <button disabled class="px-4 py-2 border border-[var(--border-secondary)] rounded-lg text-[var(--text-tertiary)] bg-[var(--bg-tertiary)] cursor-not-allowed text-sm font-bold flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 mr-1"><path d="m15 18-6-6 6-6"/></svg>
                    Previous
                </button>
                <span class="px-2 py-1 text-xs bg-[var(--button-primary-bg)] text-[var(--button-primary-text)] rounded-sm">
                    1 / 1
                </span>
                <button disabled class="px-4 py-2 border border-[var(--border-secondary)] rounded-lg text-[var(--text-tertiary)] bg-[var(--bg-tertiary)] cursor-not-allowed text-sm font-bold flex items-center">
                    Next
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 ml-1"><path d="m9 18 6-6-6-6"/></svg>
                </button>
            </div>
        </div>
    </div>
</div>
