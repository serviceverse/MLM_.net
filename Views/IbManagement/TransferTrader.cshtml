@{
    ViewData["Title"] = "Transfer Trader";
}

<div class="p-2 md:p-4">
    <div class="mb-4 flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-[var(--text-primary)]">Transfer Trader</h1>
            <p class="text-sm text-[var(--text-secondary)] mt-1">Move a trader from one IB to another IB</p>
        </div>
    </div>

    <!-- Main Card -->
    <div class="bg-white border border-[var(--border-secondary)] rounded-sm shadow-none p-4 md:p-6 max-w-2xl">
        <form class="space-y-4">
            
            <!-- Trader Selection -->
            <div class="space-y-1.5">
                <label class="block text-[var(--text-primary)] text-xs font-semibold mb-1">Select Trader <span class="text-red-500">*</span></label>
                
                <div class="relative">
                    <select class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-1.5 px-3 text-xs focus:outline-none focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)] appearance-none">
                        <option value="">Choose a trader...</option>
                        <!-- Options would be populated from ViewBag.Traders -->
                    </select>
                    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-[var(--text-secondary)]">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                    </div>
                </div>
            </div>

            <!-- Select New IB -->
            <div class="space-y-1.5">
                <label class="block text-[var(--text-primary)] text-xs font-semibold mb-1">Transfer To IB <span class="text-red-500">*</span></label>
                
                <div class="relative">
                    <select class="w-full bg-[var(--bg-tertiary)] border border-[var(--border-secondary)] text-[var(--text-primary)] rounded-sm py-1.5 px-3 text-xs focus:outline-none focus:border-[var(--button-primary-bg)] focus:ring-1 focus:ring-[var(--button-primary-bg)] appearance-none">
                        <option value="">Choose IB...</option>
                        <!-- Options would be populated from ViewBag.Ibs -->
                    </select>
                    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-[var(--text-secondary)]">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                    </div>
                </div>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="bg-[var(--button-primary-bg)] hover:bg-[var(--button-primary-hover-bg)] text-[var(--button-primary-text)] px-4 py-2 rounded-sm text-xs font-semibold transition-colors mt-4">
                Transfer Trader
            </button>
        </form>
    </div>

    <!-- Info Section -->
    <div class="mt-4 max-w-2xl bg-[var(--bg-secondary)]/50 border border-[var(--border-primary)] rounded-sm p-4">
        <div class="space-y-1 text-xs text-[var(--text-secondary)]">
            <p>• This will move the trader to the new IB immediately.</p>
            <p>• All future commissions will use the NEW IB.</p>
            <p>• Old commissions before transfer remain unchanged.</p>
        </div>
    </div>
</div>
